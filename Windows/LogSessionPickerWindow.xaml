<Window x:Class="AIStudio.Windows.LogSessionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520"
        Height="480"
        WindowStartupLocation="CenterOwner"
        Background="Black"
        ResizeMode="CanResizeWithGrip"
        PreviewKeyDown="Window_PreviewKeyDown">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

    <Style x:Key="MatrixTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#00FF00"/>
      <Setter Property="FontFamily" Value="Consolas, Courier New"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="MatrixButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#002000"/>
      <Setter Property="Foreground" Value="#00FF00"/>
      <Setter Property="BorderBrush" Value="#00FF00"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="12,5"/>
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#004000"/>
          <Setter Property="Foreground" Value="#80FF80"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="MatrixTextBoxStyle" TargetType="TextBox">
      <Setter Property="Background" Value="#002000"/>
      <Setter Property="Foreground" Value="#00FF00"/>
      <Setter Property="BorderBrush" Value="#00FF00"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="FontFamily" Value="Consolas, Courier New"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="CaretBrush" Value="#00FF00"/>
    </Style>

    <Style x:Key="MatrixCheckBoxStyle" TargetType="CheckBox">
      <Setter Property="Foreground" Value="#00FF00"/>
      <Setter Property="FontFamily" Value="Consolas, Courier New"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Margin" Value="0,4"/>
      <Setter Property="Padding" Value="4,2"/>
    </Style>
  </Window.Resources>

  <Border BorderBrush="#00FF00" BorderThickness="1" Margin="8" Padding="10" Background="#080808">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock x:Name="HeaderText" Grid.Row="0" Style="{StaticResource MatrixTextStyle}" FontWeight="Bold" FontSize="14"
                 Margin="0,0,0,10"/>

      <TextBlock Grid.Row="1" Style="{StaticResource MatrixTextStyle}" Text="Фильтр по дате/времени:" Margin="0,0,0,4"/>
      <TextBox Grid.Row="2" Style="{StaticResource MatrixTextBoxStyle}"
               Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
               Margin="0,0,0,8"
               ToolTip="Подстрока в подписи сессии, например 31.05.2026 или 08:17"/>

      <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"
                    BorderBrush="#004000" BorderThickness="1" Background="#101010" Padding="8">
        <ItemsControl ItemsSource="{Binding Items}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <CheckBox Style="{StaticResource MatrixCheckBoxStyle}"
                        Content="{Binding DisplayLabel}"
                        IsChecked="{Binding IsChecked, Mode=TwoWay}"
                        Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <Grid Grid.Row="4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal">
          <Button Content="ВСЕ" Style="{StaticResource MatrixButtonStyle}" Margin="0,0,8,0"
                  Command="{Binding SelectAllCommand}"/>
          <Button Content="СНЯТЬ" Style="{StaticResource MatrixButtonStyle}"
                  Command="{Binding ClearAllCommand}"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Content="ПРИМЕНИТЬ" Style="{StaticResource MatrixButtonStyle}" Margin="0,0,8,0"
                  Click="ApplyButton_Click" IsDefault="True"/>
          <Button Content="ОТМЕНА" Style="{StaticResource MatrixButtonStyle}"
                  Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
