<Window x:Class="AIStudio.Windows.ProjectDirectoryTemplateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Шаблон каталогов проекта"
        Height="440" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinHeight="300" MinWidth="340"
        ShowInTaskbar="False">
  <DockPanel Margin="12">
    <TextBlock DockPanel.Dock="Top"
               TextWrapping="Wrap"
               Margin="0,0,0,10"
               Foreground="#FF333333"
               Text="Структура каталогов по умолчанию (только просмотр). Файл настроек студии в папке Settings: Settings.xml."/>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Закрыть"
              MinWidth="100"
              Padding="14,5"
              IsDefault="True"
              Click="CloseButton_Click"/>
    </StackPanel>
    <TreeView x:Name="TemplateTree"
              BorderThickness="1"
              Padding="4">
      <TreeView.ItemTemplate>
        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
          <TextBlock Text="{Binding Name}" Margin="0,1"/>
        </HierarchicalDataTemplate>
      </TreeView.ItemTemplate>
    </TreeView>
  </DockPanel>
</Window>
