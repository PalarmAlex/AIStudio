<Window x:Class="AIStudio.Windows.ScenarioRunProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выполняется сценарий"
        Width="520" Height="168"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
  <Border Padding="18,16" Background="#FFF8F9FA">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <TextBlock x:Name="StatusTextBlock"
                 Grid.Row="0"
                 Text="Запуск сценария…"
                 FontSize="14"
                 FontWeight="SemiBold"
                 Foreground="#FF263238"
                 TextWrapping="Wrap"
                 MaxWidth="480"/>
      <ProgressBar Grid.Row="1"
                   IsIndeterminate="True"
                   Height="12"
                   Margin="0,14,0,0"
                   BorderThickness="0"
                   Background="#FFECEFF1"
                   Foreground="#FF2196F3"/>
      <TextBlock x:Name="FooterTextBlock"
                 Grid.Row="2"
                 Text="Выполняется сценарий — не закрывайте приложение до завершения."
                 FontSize="11"
                 Foreground="#FF78909C"
                 TextWrapping="Wrap"
                 Margin="0,10,0,0"/>
    </Grid>
  </Border>
</Window>
