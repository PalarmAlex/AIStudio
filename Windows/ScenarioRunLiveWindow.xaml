<Window x:Class="AIStudio.Windows.ScenarioRunLiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Результат прогона сценария"
        Height="560" Width="980"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="0" Margin="0,0,0,8">
      <TextBlock TextWrapping="Wrap" FontSize="13" Text="{Binding SummaryText}"/>
      <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" Foreground="#FF616161" FontSize="12"
                 Text="Таблица заполняется по памяти «Системных логов» после завершения прогона (по каждому шагу — снимок на соответствующем глобальном пульсе)."/>
    </StackPanel>
    <DataGrid Grid.Row="1"
              ItemsSource="{Binding Rows}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              HeadersVisibility="Column"
              GridLinesVisibility="Horizontal"
              AlternatingRowBackground="#FFF5F5F5">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Шаг" Binding="{Binding StepIndex}" Width="48"/>
        <DataGridTextColumn Header="№ пульса" Binding="{Binding PulseWithinScenario}" Width="72"/>
        <DataGridTextColumn Header="Состояние" Binding="{Binding State}" Width="88"/>
        <DataGridTextColumn Header="Стиль" Binding="{Binding Style}" Width="72"/>
        <DataGridTextColumn Header="Тема" Binding="{Binding Theme}" Width="56"/>
        <DataGridTextColumn Header="Триггер" Binding="{Binding Trigger}" Width="80"/>
        <DataGridTextColumn Header="ОР/УМ" Binding="{Binding OrUm}" Width="72"/>
        <DataGridTextColumn Header="Б/у рефлекс" Binding="{Binding GeneticReflex}" Width="88"/>
        <DataGridTextColumn Header="Усл. рефлекс" Binding="{Binding ConditionReflex}" Width="88"/>
        <DataGridTextColumn Header="Автоматизм" Binding="{Binding Automatizm}" Width="88"/>
        <DataGridTextColumn Header="Цепочка РФ" Binding="{Binding ReflexChain}" Width="88"/>
        <DataGridTextColumn Header="Цепочка АВ" Binding="{Binding AutomatizmChain}" Width="88"/>
        <DataGridTextColumn Header="Цикл М" Binding="{Binding MainCycle}" Width="72"/>
      </DataGrid.Columns>
    </DataGrid>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="Сохранить в файл…" Padding="12,6" Margin="0,0,8,0"
              Command="{Binding SaveToFileCommand}" IsDefault="True"/>
      <Button Content="Закрыть" Padding="12,6" Click="CloseButton_OnClick"/>
    </StackPanel>
  </Grid>
</Window>
