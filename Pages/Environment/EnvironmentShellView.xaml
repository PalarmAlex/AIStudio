<UserControl x:Class="AIStudio.Pages.SymbiontEnv.EnvironmentShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AIStudio.Converters"
             xmlns:env="clr-namespace:AIStudio.ViewModels.SymbiontEnv"
             xmlns:controls="clr-namespace:AIStudio.Controls.Environment"
             xmlns:pages="clr-namespace:AIStudio.Pages.SymbiontEnv">
  <UserControl.Resources>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    <Style x:Key="ShellTabButtonStyle" TargetType="Button">
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="Margin" Value="0,0,4,0"/>
      <Setter Property="Background" Value="#FFF0F0F0"/>
      <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
  </UserControl.Resources>

  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,6">
      <TextBlock Text="{Binding ShellTitle}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
      <Button Content="Сохранить"
              HorizontalAlignment="Right"
              Command="{Binding SaveCommand}"
              Style="{StaticResource ActionButtonStyle}"
              ToolTip="Сохранить активную вкладку"/>
    </Grid>

    <TextBlock Grid.Row="1"
               Text="{Binding PulseWarningMessage}"
               Foreground="{Binding WarningMessageColor}"
               FontStyle="Italic"
               TextWrapping="Wrap"
               Margin="0,0,0,6"
               Visibility="{Binding IsEditingEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
      <Button Content="Обзор" Style="{StaticResource ShellTabButtonStyle}" Command="{Binding NavigateTabCommand}" CommandParameter="{x:Static env:EnvironmentShellTab.Overview}"/>
      <Button Content="Триггеры" Style="{StaticResource ShellTabButtonStyle}" Command="{Binding NavigateTabCommand}" CommandParameter="{x:Static env:EnvironmentShellTab.Triggers}"/>
      <Button Content="Рецепты" Style="{StaticResource ShellTabButtonStyle}" Command="{Binding NavigateTabCommand}" CommandParameter="{x:Static env:EnvironmentShellTab.Recipes}"/>
      <Button Content="Давление" Style="{StaticResource ShellTabButtonStyle}" Command="{Binding NavigateTabCommand}" CommandParameter="{x:Static env:EnvironmentShellTab.Pressure}"/>
    </StackPanel>

    <ContentControl Grid.Row="3" Content="{Binding ActiveChild}">
      <ContentControl.Resources>
        <DataTemplate DataType="{x:Type env:EnvironmentBehaviorOverviewViewModel}">
          <pages:EnvironmentBehaviorOverviewView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type env:EnvironmentTriggersViewModel}">
          <pages:EnvironmentTriggersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type env:EnvironmentRecipesRegistryViewModel}">
          <pages:EnvironmentRecipesRegistryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type env:EnvironmentRecipeEditorViewModel}">
          <pages:EnvironmentRecipeEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type env:EnvironmentPressureRulesViewModel}">
          <pages:EnvironmentPressureRulesView/>
        </DataTemplate>
      </ContentControl.Resources>
    </ContentControl>

    <Grid Grid.Row="4" Margin="0,8,0,0">
      <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="#FF555555"/>
      <Button Content="Отменить"
              HorizontalAlignment="Right"
              Command="{Binding DiscardCommand}"
              Style="{StaticResource RedButtonStyle}"
              ToolTip="Перезагрузить активную вкладку"/>
    </Grid>
  </Grid>
</UserControl>
