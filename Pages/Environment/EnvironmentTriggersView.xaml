<UserControl x:Class="AIStudio.Pages.SymbiontEnv.EnvironmentTriggersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AIStudio.Converters"
             xmlns:controls="clr-namespace:AIStudio.Controls.Environment">
  <UserControl.Resources>
    <converters:IntDictionaryToStringConverter x:Key="IntDictionaryToStringConverter"/>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
  </UserControl.Resources>

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="{Binding CurrentAgentTitle}"
               FontSize="18"
               FontWeight="SemiBold"
               HorizontalAlignment="Center"
               Margin="0,0,0,5"
               Foreground="#FF333333"/>

    <TextBlock Grid.Row="1"
               HorizontalAlignment="Left"
               Margin="0,0,0,10"
               Foreground="#FF333333"
               TextWrapping="Wrap">
      <Run Text="{Binding CurrentAgentDescription.Text}"/>
      <Hyperlink Command="{Binding CurrentAgentDescription.OpenLinkCommand}">
        <Run Text="{Binding CurrentAgentDescription.LinkText}"/>
      </Hyperlink>
    </TextBlock>

    <Border Grid.Row="2" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8" Background="#FFF9F9F9">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="120"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="ID" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
        <TextBox Grid.Column="1" Text="{Binding FilterIdText, UpdateSourceTrigger=PropertyChanged}" Padding="4,3" Margin="0,0,16,0"/>
        <TextBlock Grid.Column="2" Text="Название" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
        <TextBox Grid.Column="3" Text="{Binding FilterTitleText, UpdateSourceTrigger=PropertyChanged}" Padding="4,3" Margin="0,0,16,0"/>
        <Button Grid.Column="4" Content="Применить" Padding="12,6" Margin="0,0,8,0" Command="{Binding ApplyFiltersCommand}"/>
        <Button Grid.Column="5" Content="Сброс" Padding="12,6" Command="{Binding ResetFiltersCommand}"/>
      </Grid>
    </Border>

    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="630"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <DockPanel Grid.Column="0" Margin="0,0,12,0">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
          <Button Content="+ Новый" Command="{Binding AddTriggerCommand}" Padding="10,4" Margin="0,0,8,0"/>
          <Button Content="Удалить" Command="{Binding DeleteSelectedCommand}" Style="{StaticResource RedButtonStyle}" Padding="10,4"/>
        </StackPanel>
        <DataGrid ItemsSource="{Binding Triggers}"
                  SelectedItem="{Binding SelectedTrigger, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  BorderBrush="#FFE0E0E0"
                  BorderThickness="1"
                  RowBackground="#FFF9F9F9"
                  AlternatingRowBackground="White"
                  GridLinesVisibility="Horizontal">
          <DataGrid.Columns>
            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="140"/>
            <DataGridTextColumn Header="Название" Binding="{Binding DisplayName}" Width="*"/>
            <DataGridTextColumn Header="Событие" Binding="{Binding EventSummary}" Width="*"/>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>

      <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
        <StackPanel DataContext="{Binding SelectedTrigger}" IsEnabled="{Binding DataContext.IsEditingEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}">
          <TextBlock Text="Детали триггера" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <TextBlock Text="ID" FontWeight="SemiBold"/>
          <Grid Margin="0,4,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Grid.Column="1" Content="Каталог" Margin="8,0,0,0" Padding="10,4"
                    Command="{Binding DataContext.PickTriggerIdFromCatalogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
          </Grid>
          <TextBlock Text="Название" FontWeight="SemiBold"/>
          <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>

          <TextBlock Text="homeostasis_deltas (mechanical path)" FontWeight="SemiBold"/>
          <TextBlock Margin="0,0,0,4" Foreground="#FF666666" TextWrapping="Wrap"
                     Text="Дельты параметров гомеostasis при срабатывании pressure rules. Двойной щелчок или «Изменить…»."/>
          <Grid Margin="0,4,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding HomeostasisDeltas, Converter={StaticResource IntDictionaryToStringConverter}}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       MouseDown="HomeostasisDeltas_MouseDown"/>
            <Button Grid.Column="1" Content="Изменить…" Margin="8,0,0,0" Padding="10,4"
                    Command="{Binding DataContext.EditHomeostasisDeltasCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
          </Grid>
          <TextBlock Margin="0,0,0,8"
                     Foreground="#FFD32F2F"
                     FontSize="12"
                     Text="{Binding DataContext.HomeostasisDeltasValidationMessage, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding DataContext.HomeostasisDeltasValidationMessage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding DataContext.HomeostasisDeltasValidationMessage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding DataContext.HomeostasisDeltasValidationMessage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Не заполнено поле">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <TextBlock Text="reflex_trigger_command_pattern_id" FontWeight="SemiBold"/>
          <TextBlock Margin="0,0,0,4" Foreground="#FF666666" TextWrapping="Wrap"
                     Text="Справочная связь с genetic reflex (CommandPhrases.dat). Не запускает runtime-flush в Velum."/>
          <Grid Margin="0,4,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding ReflexTriggerCommandPatternId}"
                     IsReadOnly="True"/>
            <Button Grid.Column="1" Content="Выбрать…" Margin="8,0,8,0" Padding="10,4"
                    Command="{Binding DataContext.PickCommandPatternCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding ReflexTriggerCommandPatternText}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>
          </Grid>
          <TextBlock Margin="0,0,0,8"
                     Foreground="#FFD32F2F"
                     FontSize="12"
                     Text="{Binding DataContext.CommandPatternValidationMessage, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding DataContext.CommandPatternValidationMessage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Не заполнено поле">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <TextBlock Text="Событие" FontWeight="SemiBold" Margin="0,0,0,6"/>
          <controls:SchemaActionPanel DataContext="{Binding DataContext.EventSchema, RelativeSource={RelativeSource AncestorType=UserControl}}" MinHeight="220"/>
          <TextBlock Margin="0,6,0,0"
                     Foreground="#FFD32F2F"
                     FontSize="12"
                     Text="{Binding DataContext.EventKindValidationMessage, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding DataContext.EventKindValidationMessage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Не заполнено поле">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
          <TextBlock Text="Связи" FontWeight="SemiBold" Margin="0,8,0,4"/>
          <ItemsControl ItemsSource="{Binding DataContext.Links, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Margin="0,2" TextWrapping="Wrap">
                  <Run Text="{Binding Category, Mode=OneWay}" FontWeight="SemiBold"/>
                  <Run Text=": "/>
                  <Run Text="{Binding Title, Mode=OneWay}"/>
                  <Run Text=" — "/>
                  <Run Text="{Binding Detail, Mode=OneWay}"/>
                </TextBlock>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <Grid Grid.Row="4" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0"
                 Text="{Binding PulseWarningMessage}"
                 Foreground="{Binding WarningMessageColor}"
                 FontStyle="Italic"
                 VerticalAlignment="Center"
                 Margin="8,0,0,0"
                 TextWrapping="Wrap"
                 Visibility="{Binding IsEditingEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Сохранить"
                Command="{Binding SaveCommand}"
                IsEnabled="{Binding IsEditingEnabled}"
                Style="{StaticResource ActionButtonStyle}"/>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
