<UserControl x:Class="AIStudio.Pages.SymbiontEnv.EnvironmentRecipeEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="400">
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
      <Button Content="← Назад к реестру" Padding="10,6" Margin="0,0,10,0" Click="BackButton_Click"/>
      <TextBlock Text="{Binding CurrentAgentTitle}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
    </StackPanel>

    <TabControl Grid.Row="1" DataContext="{Binding Model}">
      <TabItem Header="Сведения">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
          <StackPanel>
            <TextBlock Text="ID" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
            <TextBlock Text="Название" FontWeight="SemiBold"/>
            <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
            <TextBlock Text="Описание" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="60" Margin="0,4,0,8"/>
            <TextBlock Text="Адаптивное действие (G_AD)" FontWeight="SemiBold"/>
            <Grid Margin="0,4,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0" Text="{Binding AdaptiveActionId}" IsReadOnly="True"/>
              <Button Grid.Column="1" Content="Выбрать…" Margin="8,0,0,0" Click="PickAdaptiveAction_Click"/>
            </Grid>
            <TextBlock Text="Уровень риска" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding DataContext.RiskTierChoices, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      SelectedItem="{Binding RiskTier}" Margin="0,4,0,8"/>
            <CheckBox Content="Реактивное исполнение (reactive_eligible)" IsChecked="{Binding ReactiveEligible}" Margin="0,0,0,8"/>
            <TextBlock Text="Рекомендуемые воздействия (триггеры)" FontWeight="SemiBold"/>
            <Grid Margin="0,4,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0" Text="{Binding RecommendedTriggersDisplay}" IsReadOnly="True"/>
              <Button Grid.Column="1" Content="Выбрать…" Margin="8,0,0,0" Click="PickRecommendedTriggers_Click"/>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
      <TabItem Header="Предусловия">
        <StackPanel Margin="12">
          <CheckBox Content="Деталь (part)" IsChecked="{Binding DocumentKindPart}" Margin="0,4"/>
          <CheckBox Content="Сборка (assembly)" IsChecked="{Binding DocumentKindAssembly}" Margin="0,4"/>
          <CheckBox Content="Чертёж (drawing)" IsChecked="{Binding DocumentKindDrawing}" Margin="0,4"/>
          <CheckBox Content="Не в режиме эскиза" IsChecked="{Binding NotSketchEdit}" Margin="0,8,0,4"/>
          <CheckBox Content="Не read-only" IsChecked="{Binding NotReadOnly}" Margin="0,4"/>
          <CheckBox Content="Требуется checkout PDM" IsChecked="{Binding PdmCheckoutRequired}" Margin="0,4"/>
        </StackPanel>
      </TabItem>
      <TabItem Header="Шаги">
        <Grid Margin="4">
          <DataGrid x:Name="StepsGrid" ItemsSource="{Binding Steps}" AutoGenerateColumns="False"
                    CanUserAddRows="True" CanUserDeleteRows="True">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Тип" Binding="{Binding StepType, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
              <DataGridTextColumn Header="Параметры (key=value)" Binding="{Binding ParametersText, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>
      <TabItem Header="Прочее">
        <StackPanel Margin="12">
          <TextBlock Text="postcondition_log" FontWeight="SemiBold"/>
          <TextBox Text="{Binding PostconditionLog, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
          <TextBlock Text="test_notes" FontWeight="SemiBold"/>
          <TextBox Text="{Binding TestNotes, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80"/>
        </StackPanel>
      </TabItem>
    </TabControl>

    <Grid Grid.Row="2" Margin="0,8,0,0">
      <TextBlock Text="{Binding PulseWarningMessage}" Foreground="{Binding WarningMessageColor}" VerticalAlignment="Center"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Сохранить" Padding="12,6" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
        <Button Content="Отмена" Padding="12,6" Command="{Binding CancelCommand}"/>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
