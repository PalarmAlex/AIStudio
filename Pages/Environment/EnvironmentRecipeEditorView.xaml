<UserControl x:Class="AIStudio.Pages.SymbiontEnv.EnvironmentRecipeEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AIStudio.Controls.Environment"
             xmlns:converters="clr-namespace:AIStudio.Converters"
             MinHeight="400">

  <UserControl.Resources>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
  </UserControl.Resources>


  <Grid Margin="4">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="{Binding EditorTitle}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
      <Button Content="Общее" Padding="12,6" Margin="0,0,4,0" Click="TabGeneral_Click"/>
      <Button Content="Шаги" Padding="12,6" Margin="0,0,4,0" Click="TabSteps_Click"/>
    </StackPanel>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <StackPanel x:Name="GeneralPanel">
          <StackPanel DataContext="{Binding Model}" IsEnabled="{Binding DataContext.IsEditingEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <TextBlock Text="ID" FontWeight="SemiBold"
                       ToolTip="Внутреннее имя рецепта. У каждого рецепта должно быть своё, без повторов."/>
            <Grid Margin="0,4,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0"
                       Text="{Binding DataContext.RecipeId, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="Внутреннее имя рецепта. У каждого рецепта должно быть своё, без повторов."/>
              <Button Grid.Column="1" Content="Выбрать…" Margin="8,0,8,0" Padding="10,4" Click="PickRecipeId_Click"/>
              <TextBlock Grid.Column="2" Text="{Binding DataContext.RecipeIdDescription, RelativeSource={RelativeSource AncestorType=UserControl}}" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#FF555555"/>
            </Grid>
            <TextBlock Text="Название" FontWeight="SemiBold"/>
            <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" TextChanged="ModelField_TextChanged"/>
            <TextBlock Text="Описание" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="48" Margin="0,4,0,8" TextChanged="ModelField_TextChanged"/>
            <TextBlock Text="Моторное действие (G_AD)" FontWeight="SemiBold"
                       ToolTip="Действие симбионта, которое запускает этот рецепт.&#x0a;Когда симбион его выполняет, среда делает шаги рецепта."/>
            <Grid Margin="0,4,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0"
                       Text="{Binding DataContext.AdaptiveActionDisplay, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"
                       IsReadOnly="True"
                       ToolTip="Действие симбионта, которое запускает этот рецепт.&#x0a;Когда симбион его выполняет, среда делает шаги рецепта."/>
              <Button Grid.Column="1" Content="Выбрать…" Margin="8,0,8,0" Padding="10,4" Click="PickAdaptiveAction_Click"/>
              <TextBlock Grid.Column="2" Text="{Binding DataContext.AdaptiveActionDescription, RelativeSource={RelativeSource AncestorType=UserControl}}" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#FF555555"/>
            </Grid>
            <CheckBox Content="Реактивное исполнение"
                      IsChecked="{Binding ReactiveEligible}"
                      Margin="0,0,0,8"
                      Checked="ModelField_Changed"
                      Unchecked="ModelField_Changed"
                      ToolTip="Если включено — рецепт выполняется сам, когда симбион делает выбранное действие.&#x0a;Если выключено — рецепт только хранится, автоматически не запускается."/>
          </StackPanel>
        </StackPanel>

        <StackPanel x:Name="StepsPanel" Visibility="Collapsed">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="+ Шаг" Command="{Binding AddInvokeStepCommand}" Padding="10,4" Margin="0,0,8,0"/>
            <Button Content="Удалить" Command="{Binding DeleteSelectedStepsCommand}" Style="{StaticResource RedButtonStyle}" Padding="10,4"/>
          </StackPanel>

          <DataGrid x:Name="StepsGrid"
                    ItemsSource="{Binding Model.Steps}"
                    SelectedItem="{Binding SelectedStep, Mode=TwoWay}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    SelectionMode="Single"
                    IsReadOnly="True"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1"
                    MinHeight="140"
                    Margin="0,0,0,8"
                    LoadingRow="StepsGrid_LoadingRow">

            <DataGrid.Columns>
              <DataGridTextColumn Header="№" Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}" Width="40"/>
              <DataGridTextColumn Header="Действие" Binding="{Binding DisplayAction}" Width="200"/>
              <DataGridTextColumn Header="Кратко" Binding="{Binding Summary}" Width="*"/>
            </DataGrid.Columns>

          </DataGrid>
          <controls:SchemaActionPanel DataContext="{Binding StepHandlerSchema}" MinHeight="200"/>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="3" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0"
                 Text="{Binding PulseWarningMessage}"
                 Foreground="{Binding WarningMessageColor}"
                 FontStyle="Italic"
                 VerticalAlignment="Center"
                 Margin="8,0,0,0"
                 TextWrapping="Wrap"
                 Visibility="{Binding IsEditingEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Отмена"
                Command="{Binding CancelCommand}"
                Style="{StaticResource AgentButtonStyle}"
                Margin="0,0,8,0"/>

        <Button Content="Сохранить"
                Command="{Binding SaveCommand}"
                IsEnabled="{Binding IsEditingEnabled}"
                Style="{StaticResource ActionButtonStyle}"/>
      </StackPanel>
    </Grid>
  </Grid>

</UserControl>