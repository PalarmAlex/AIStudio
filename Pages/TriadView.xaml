<UserControl x:Class="AIStudio.Pages.TriadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:AIStudio.Converters"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1100">

  <UserControl.Resources>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

    <Style x:Key="TriadPhaseItemStyle" TargetType="ComboBoxItem">
      <Setter Property="ToolTip" Value="{Binding Description}"/>
    </Style>

    <Style x:Key="EditableTriadGrid" TargetType="DataGrid">
      <Setter Property="IsReadOnly" Value="{Binding IsCouplingReadOnly}"/>
      <Setter Property="CanUserAddRows" Value="True"/>
      <Setter Property="CanUserDeleteRows" Value="True"/>
      <Setter Property="AutoGenerateColumns" Value="False"/>
    </Style>
  </UserControl.Resources>

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="180"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Триада: Creature ↔ Niche (среда)"
               FontSize="18"
               FontWeight="SemiBold"
               Margin="0,0,0,8"
               Foreground="#FF333333"/>

    <Border Grid.Row="1"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10"
            Margin="0,0,0,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Фаза эксперимента:" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <ComboBox Grid.Row="0" Grid.Column="1"
                  ItemsSource="{Binding FilteredPhaseOptions}"
                  SelectedValue="{Binding SelectedPhase, Mode=TwoWay}"
                  SelectedValuePath="Phase"
                  DisplayMemberPath="Title"
                  ItemContainerStyle="{StaticResource TriadPhaseItemStyle}"
                  ToolTip="{Binding SelectedPhaseDescription}"
                  MinWidth="280"
                  Margin="0,0,8,4"
                  IsEnabled="{Binding CanEditConfig}"/>
        <Button Grid.Row="0" Grid.Column="2"
                Content="Применить фазу"
                Command="{Binding ApplyPhaseCommand}"
                Padding="12,4"
                Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                   Text="{Binding PhaseRestrictionHint}"
                   Foreground="#FFB45309"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4"
                   Visibility="{Binding PhaseRestrictionHint, Converter={StaticResource StringToVisibilityConverter}}"/>

        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
          <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#FF555555" Margin="0,0,16,0"/>
          <TextBlock Text="run:" Foreground="#FF777777"/>
          <TextBlock Text="{Binding ExperimentRunId}" Margin="4,0,12,0"/>
          <TextBlock Text="mapping v" Foreground="#FF777777"/>
          <TextBlock Text="{Binding CouplingMappingVersion}" Margin="4,0,12,0"/>
          <TextBlock Text="role:" Foreground="#FF777777"/>
          <TextBlock Text="{Binding NicheRoleProfileId}" Margin="4,0,12,0"/>
          <TextBlock Text="contour:" Foreground="#FF777777"/>
          <TextBlock Text="{Binding ContourId}" Margin="4,0,12,0"/>
          <TextBlock Text="probe:" Foreground="#FF777777"/>
          <TextBlock Text="{Binding LastContourProbeKey, TargetNullValue=—}" Margin="4,0,0,0"/>
        </StackPanel>
        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                   Text="{Binding ContourProbeHint}"
                   Foreground="#FF555555"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0"
                   FontSize="11"
                   Visibility="{Binding ContourProbeHint, Converter={StaticResource StringToVisibilityConverter}}"/>
      </Grid>
    </Border>

    <StackPanel Grid.Row="2" Margin="0,0,0,8">
      <WrapPanel>
        <Button Content="Сохранить в Environment" Command="{Binding SaveCouplingCommand}" Margin="0,0,8,4" Padding="10,4"
                FontWeight="SemiBold"
                ToolTip="Записать coupling, niche_params, triad_config и contour_probes в каталог Environment"/>
        <CheckBox Content="mapping version +1" IsChecked="{Binding IncrementMappingVersionOnSave, Mode=TwoWay}"
                  VerticalAlignment="Center" Margin="0,0,12,4"
                  IsEnabled="{Binding CanEditConfig}"/>
        <Button Content="Перезагрузить" Command="{Binding ReloadConfigCommand}" Margin="0,0,8,4" Padding="10,4"/>
        <Button Content="Каталог Environment" Command="{Binding OpenEnvironmentFolderCommand}" Margin="0,0,8,4" Padding="10,4"/>
        <Button Content="Init Niche" Command="{Binding RecordRunStartCommand}" Margin="0,0,8,4" Padding="10,4"/>
        <Button Content="Лог диады" Command="{Binding OpenDyadLogCommand}" Margin="0,0,8,4" Padding="10,4"/>
        <Button Content="Манифест прогона" Command="{Binding OpenRunManifestCommand}" Margin="0,0,8,4" Padding="10,4"
                ToolTip="triad_run_manifest.json — experiment_run_id и coupling_mapping_version"/>
        <Button Content="Сценарии §6.14" Command="{Binding InstallValidationScenariosCommand}" Margin="0,0,8,4" Padding="10,4"/>
        <Button Content="Метрики §13.3" Command="{Binding CheckTriadMetricsCommand}" Margin="0,0,8,4" Padding="10,4"/>
        <TextBlock Text="AOE:" VerticalAlignment="Center" Margin="4,0,4,4" Foreground="#FF777777"/>
        <TextBlock VerticalAlignment="Center" Margin="0,0,0,4">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Text" Value="ожидание выкл"/>
              <Setter Property="Foreground" Value="#FF777777"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding WaitingForNicheResponse}" Value="True">
                  <Setter Property="Text" Value="ожидание вкл"/>
                  <Setter Property="Foreground" Value="#FF0066CC"/>
                  <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </WrapPanel>
      <TextBlock Text="{Binding ValidationScenariosHint}" Foreground="#FF555555" TextWrapping="Wrap" Margin="0,2,0,0" FontSize="11"/>
      <TextBlock Text="{Binding RunManifestHint}" Foreground="#FF555555" TextWrapping="Wrap" Margin="0,2,0,0" FontSize="11"/>
      <TextBlock Text="{Binding TriadMetricsHint}" Foreground="#FF555555" TextWrapping="Wrap" Margin="0,2,0,0" FontSize="11"/>
      <TextBlock Foreground="#FF888888" TextWrapping="Wrap" Margin="0,4,0,0" FontSize="11"
                 Visibility="{Binding IsCouplingReadOnly, Converter={StaticResource BooleanToVisibilityConverter}}">
        Редактирование coupling недоступно во время пульсации. Остановите пульс для сохранения.
      </TextBlock>
    </StackPanel>

    <TabControl Grid.Row="3" Margin="0,0,0,8">
      <TabItem Header="Coupling">
        <Grid Margin="4">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Creature action → Niche" FontWeight="SemiBold" Margin="0,0,4,4"/>
          <DataGrid Grid.Row="0" Grid.Column="0" Style="{StaticResource EditableTriadGrid}"
                    ItemsSource="{Binding ActionCouplingRows}" Margin="0,20,4,4">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ActionId" Binding="{Binding ActionId, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
              <DataGridTextColumn Header="NicheParam" Binding="{Binding NicheParamId, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
              <DataGridTextColumn Header="Delta" Binding="{Binding Delta, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
              <DataGridTextColumn Header="Scale" Binding="{Binding Scale, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>

          <TextBlock Grid.Row="0" Grid.Column="1" Text="Operator → Niche (фаза C)" FontWeight="SemiBold" Margin="4,0,0,4"/>
          <DataGrid Grid.Row="0" Grid.Column="1" Style="{StaticResource EditableTriadGrid}"
                    ItemsSource="{Binding OperatorCouplingRows}" Margin="4,20,0,4">
            <DataGrid.Columns>
              <DataGridTextColumn Header="InfluenceId" Binding="{Binding InfluenceActionId, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
              <DataGridTextColumn Header="NicheParam" Binding="{Binding NicheParamId, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
              <DataGridTextColumn Header="Delta" Binding="{Binding Delta, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
              <DataGridTextColumn Header="Scale" Binding="{Binding Scale, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>

          <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="Niche → Creature" FontWeight="SemiBold" Margin="0,8,0,4"/>
          <DataGrid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource EditableTriadGrid}"
                    ItemsSource="{Binding NicheMappingRows}" Margin="0,28,0,0">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Niche" Binding="{Binding NicheParamId, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
              <DataGridTextColumn Header="Creature" Binding="{Binding CreatureParamId, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
              <DataGridTextColumn Header="Scale" Binding="{Binding Scale, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
              <DataGridTextColumn Header="Lag" Binding="{Binding LagPulses, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <TabItem Header="Niche params">
        <Grid Margin="4">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="niche_params.dat — начальные значения и дрейф" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <DataGrid Grid.Row="1" Style="{StaticResource EditableTriadGrid}" ItemsSource="{Binding NicheParamDefRows}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ParamId" Binding="{Binding ParamId, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
              <DataGridTextColumn Header="InitialValue" Binding="{Binding InitialValue, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
              <DataGridTextColumn Header="SpeedPerPulse" Binding="{Binding SpeedPerPulse, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
          <TextBlock Grid.Row="2" Text="Live-снимок Niche (текущий такт)" FontWeight="SemiBold" Margin="0,12,0,4"/>
          <DataGrid Grid.Row="3" ItemsSource="{Binding NicheParameters}" IsReadOnly="True" CanUserAddRows="False"
                    AutoGenerateColumns="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ParamId" Binding="{Binding ParamId}" Width="80"/>
              <DataGridTextColumn Header="Value" Binding="{Binding Value, StringFormat=F2}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <TabItem Header="Движок &amp; AOE">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="4">
          <Grid MaxWidth="520" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="200"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="ContourId" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ContourIdSetting, UpdateSourceTrigger=PropertyChanged}" Margin="0,4" IsEnabled="{Binding CanEditConfig}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Mapping version" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditableCouplingMappingVersion, UpdateSourceTrigger=PropertyChanged}" Margin="0,4" IsEnabled="{Binding CanEditConfig}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Спontaneous drift" VerticalAlignment="Center" Margin="0,6"/>
            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding SpontaneousDriftEnabled, Mode=TwoWay}" VerticalAlignment="Center" IsEnabled="{Binding CanEditConfig}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Full Niche engine" VerticalAlignment="Center" Margin="0,6"/>
            <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding UseFullNicheEngine, Mode=TwoWay}" VerticalAlignment="Center" IsEnabled="{Binding CanEditConfig}"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Probe contour" VerticalAlignment="Center" Margin="0,6"/>
            <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding UseProbeContour, Mode=TwoWay}" VerticalAlignment="Center" IsEnabled="{Binding CanEditConfig}"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="RoleProfile" VerticalAlignment="Center" Margin="0,6"/>
            <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding RoleProfileOptions}" SelectedItem="{Binding NicheRoleProfileIdSetting, Mode=TwoWay}" Margin="0,4" IsEnabled="{Binding CanEditConfig}"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Text="AOE Niche (§5.3)" FontWeight="SemiBold" Margin="0,12,0,4"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Baseline N" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding AoeBaselineN, UpdateSourceTrigger=PropertyChanged}" Margin="0,4" IsEnabled="{Binding CanEditConfig}"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Threshold" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding AoeThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,4" IsEnabled="{Binding CanEditConfig}"/>

            <TextBlock Grid.Row="9" Grid.Column="0" Text="Horizon K" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding AoeHorizonK, UpdateSourceTrigger=PropertyChanged}" Margin="0,4" IsEnabled="{Binding CanEditConfig}"/>

            <TextBlock Grid.Row="10" Grid.Column="0" Text="Eval window W" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding AoeEvalWindow, UpdateSourceTrigger=PropertyChanged}" Margin="0,4" IsEnabled="{Binding CanEditConfig}"/>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Контур">
        <Grid Margin="4">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="contour_probes.dat — probeKey → Niche (EnvironmentMetricProbeKey)" TextWrapping="Wrap" Margin="0,0,0,4"/>
          <DataGrid Grid.Row="1" Style="{StaticResource EditableTriadGrid}" ItemsSource="{Binding ContourProbeRows}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ProbeKey" Binding="{Binding ProbeKey, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
              <DataGridTextColumn Header="NicheParam" Binding="{Binding NicheParamId, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
              <DataGridTextColumn Header="Delta" Binding="{Binding Delta, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>
    </TabControl>

    <Border Grid.Row="4"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1"
            CornerRadius="4"
            Margin="0,0,0,8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Лог диады (AgentLogs_Dyad.jsonl)" FontWeight="SemiBold" Margin="8,6,8,4"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8,0,8,8">
          <TextBlock Text="{Binding DyadLogTail}"
                     FontFamily="Consolas, Courier New"
                     FontSize="11"
                     TextWrapping="NoWrap"/>
        </ScrollViewer>
      </Grid>
    </Border>

    <StackPanel Grid.Row="5" Orientation="Horizontal">
      <Button Content="NicheSoft" Command="{Binding ResetNicheSoftCommand}" Margin="0,0,8,0" Padding="10,4"/>
      <Button Content="CreatureSoft" Command="{Binding ResetCreatureSoftCommand}" Margin="0,0,8,0" Padding="10,4"/>
      <Button Content="DyadHard" Command="{Binding ResetDyadHardCommand}" Margin="0,0,8,0" Padding="10,4"/>
      <Button Content="Calibration" Command="{Binding ResetCalibrationCommand}" Padding="10,4"/>
      <TextBlock Text="{Binding EnvironmentFolder}" VerticalAlignment="Center" Margin="16,0,0,0"
                 Foreground="#FF888888" TextTrimming="CharacterEllipsis" MaxWidth="400"
                 ToolTip="{Binding EnvironmentFolder}"/>
    </StackPanel>

    <TextBlock Grid.Row="3"
               Text="Триада не активна — заполните coupling и нажмите «Сохранить в Environment», затем «Перезагрузить»."
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               Foreground="#FF888888"
               TextWrapping="Wrap"
               Margin="40,8,40,0"
               IsHitTestVisible="False"
               Visibility="{Binding IsTriadInactive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
  </Grid>
</UserControl>
