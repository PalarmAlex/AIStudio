<UserControl x:Class="AIStudio.Pages.Episodic.EpisodicMemoryTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AIStudio.Pages.Episodic"
             xmlns:viewmodels="clr-namespace:AIStudio.ViewModels.Episodic"
             xmlns:converters="clr-namespace:AIStudio.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">

  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    <converters:EpisodicTreeExpandConverter x:Key="EpisodicTreeExpandConverter"/>
    <HierarchicalDataTemplate DataType="{x:Type viewmodels:EpisodicTreeNodeItem}"
                              ItemsSource="{Binding Children}">
      <TextBlock Text="{Binding TextDisplay}"
                 ToolTip="{Binding TooltipText}"
                 TextTrimming="CharacterEllipsis"
                 Margin="0,1"
                 Foreground="{Binding EffectBrush}"
                 FontWeight="{Binding RowFontWeight}"/>
    </HierarchicalDataTemplate>
  </UserControl.Resources>

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Заголовок -->
    <TextBlock Grid.Row="0"
               Text="{Binding CurrentAgentTitle}"
               FontSize="18"
               FontWeight="SemiBold"
               HorizontalAlignment="Center"
               Margin="0,0,0,5"
               Foreground="#FF333333"/>

    <!-- Описание с ссылкой (как в AutomatizmsView) -->
    <TextBlock Grid.Row="1"
               HorizontalAlignment="Left"
               Margin="0,0,0,10"
               Foreground="#FF333333"
               TextWrapping="Wrap"
               Height="Auto">
      <Run Text="{Binding CurrentAgentDescription.Text}"/>
      <Hyperlink Command="{Binding CurrentAgentDescription.OpenLinkCommand}">
        <Run Text="{Binding CurrentAgentDescription.LinkText}"/>
      </Hyperlink>
    </TextBlock>

    <!-- Панель фильтров (порядок как в AutomatizmsView, без NodePID) -->
    <Border Grid.Row="2"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1"
            CornerRadius="4"
            Margin="0,0,0,10"
            Padding="5"
            Background="#FFF5F5F5">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="Фильтры:"
                   VerticalAlignment="Top"
                   Margin="0,6,12,0"
                   FontWeight="Bold"/>

        <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left">
          <!-- Строка 1 -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <StackPanel Orientation="Vertical" Margin="0,0,10,0" Width="150">
              <TextBlock Text="Интегральное состояние" FontSize="12" Margin="0,0,0,2"/>
              <ComboBox Style="{StaticResource AgentComboBoxStyle}"
                        ItemsSource="{Binding BaseConditionFilterOptions}"
                        SelectedValue="{Binding SelectedBaseConditionFilter}"
                        DisplayMemberPath="Value"
                        SelectedValuePath="Key"
                        Height="25" Cursor="Hand"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,0,10,0" Width="150">
              <TextBlock Text="Контексты реагирования" FontSize="12" Margin="0,0,0,2"/>
              <ComboBox Style="{StaticResource AgentComboBoxStyle}"
                        ItemsSource="{Binding Level2FilterOptions}"
                        SelectedValue="{Binding SelectedLevel2Filter}"
                        DisplayMemberPath="Value"
                        SelectedValuePath="Key"
                        Height="25"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,0,10,0" Width="150">
              <TextBlock Text="Полезность (эффект)" FontSize="12" Margin="0,0,0,2"/>
              <ComboBox Style="{StaticResource AgentComboBoxStyle}"
                        ItemsSource="{Binding UsefulnessFilterOptions}"
                        SelectedValue="{Binding SelectedUsefulnessFilter}"
                        DisplayMemberPath="Value"
                        SelectedValuePath="Key"
                        Height="25"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,0,10,0" Width="150">
              <TextBlock Text="Узлов на дерево" FontSize="12" Margin="0,0,0,2"/>
              <ComboBox Style="{StaticResource AgentComboBoxStyle}"
                        ItemsSource="{Binding MaxNodesOptions}"
                        SelectedValue="{Binding SelectedMaxNodes, Mode=TwoWay}"
                        DisplayMemberPath="Value"
                        SelectedValuePath="Key"
                        Height="25"
                        ToolTip="Ограничить количество отображаемых узлов"/>
            </StackPanel>
          </StackPanel>
          <!-- Строка 2 -->
          <StackPanel Orientation="Horizontal">
            <StackPanel Orientation="Vertical" Margin="0,0,10,0" Width="150">
              <TextBlock Text="Действие триггера" FontSize="12" Margin="0,0,0,2"/>
              <ComboBox Style="{StaticResource AgentComboBoxStyle}"
                        ItemsSource="{Binding PerceptionActionFilterOptions}"
                        SelectedValue="{Binding SelectedPerceptionActionFilterId}"
                        DisplayMemberPath="Value"
                        SelectedValuePath="Key"
                        Height="25"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,0,10,0" Width="150">
              <TextBlock Text="Действие акции" FontSize="12" Margin="0,0,0,2"/>
              <ComboBox Style="{StaticResource AgentComboBoxStyle}"
                        ItemsSource="{Binding ActionFilterOptions}"
                        SelectedValue="{Binding SelectedActionFilterId}"
                        DisplayMemberPath="Value"
                        SelectedValuePath="Key"
                        Height="25"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,0,10,0" Width="150">
              <TextBlock Text="Фраза триггера" FontSize="12" Margin="0,0,0,2"/>
              <TextBox Style="{StaticResource AgentFilterTextBoxStyle}"
                       Text="{Binding FilterPhrasePerceptionInput, UpdateSourceTrigger=PropertyChanged}"
                       Height="25" Width="150"
                       ToolTip="Поиск по вхождению текста в фразу образа триггера. Нажмите «Применить»."/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,0,10,0" Width="150">
              <TextBlock Text="Фраза акции" FontSize="12" Margin="0,0,0,2"/>
              <TextBox Style="{StaticResource AgentFilterTextBoxStyle}"
                       Text="{Binding FilterPhraseInput, UpdateSourceTrigger=PropertyChanged}"
                       Height="25" Width="150"
                       ToolTip="Поиск по вхождению текста в фразу образа действия. Нажмите «Применить»."/>
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <Grid Grid.Column="2" VerticalAlignment="Stretch" Margin="12,0,0,0" Width="150">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Button Grid.Row="0" Content="Применить"
                  Command="{Binding ApplyFiltersCommand}"
                  Style="{StaticResource AgentButtonStyle}"
                  Margin="0,15,0,6"
                  Height="30"
                  Width="150"
                  Cursor="Hand"
                  HorizontalAlignment="Left"
                  ToolTip="Применить фильтры"/>
          <Button Grid.Row="2" Content="Сбросить фильтры"
                  Command="{Binding ClearFiltersCommand}"
                  Style="{StaticResource AgentButtonStyle}"
                  Height="30"
                  Width="150"
                  Cursor="Hand"
                  HorizontalAlignment="Left" Margin="0,0,0,0"/>
        </Grid>
      </Grid>
    </Border>

    <!-- Таблица из трёх колонок с деревьями -->
    <Grid Grid.Row="3" Margin="0,0,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,0,3,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="#FFFFEBEE" Padding="8,6">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Плохо"
                         FontWeight="SemiBold" FontSize="13"
                         Foreground="#FFC62828" VerticalAlignment="Center" HorizontalAlignment="Left"/>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <CheckBox Content="Эмоции" IsChecked="{Binding CollapseEmotionsBad}" Margin="0,0,12,0" FontSize="11" VerticalAlignment="Center"/>
                <CheckBox Content="NodePID" IsChecked="{Binding CollapseNodePidBad}" Margin="0,0,12,0" FontSize="11" VerticalAlignment="Center"/>
                <CheckBox Content="Триггер" IsChecked="{Binding CollapseTriggerBad}" FontSize="11" VerticalAlignment="Center"/>
              </StackPanel>
            </Grid>
          </Border>
          <TreeView Grid.Row="1"
                    ItemsSource="{Binding TreeBad}"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                    Margin="4"
                    BorderThickness="0">
            <TreeView.ItemContainerStyle>
              <Style TargetType="TreeViewItem">
                <Setter Property="IsExpanded">
                  <Setter.Value>
                    <MultiBinding Converter="{StaticResource EpisodicTreeExpandConverter}">
                      <Binding Path="Level"/>
                      <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.CollapseEmotionsBad"/>
                      <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.CollapseNodePidBad"/>
                      <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.CollapseTriggerBad"/>
                    </MultiBinding>
                  </Setter.Value>
                </Setter>
              </Style>
            </TreeView.ItemContainerStyle>
          </TreeView>
        </Grid>
      </Border>

      <Border Grid.Column="1" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" Margin="3,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="#FFFFFFE0" Padding="8,6">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Норма"
                         FontWeight="SemiBold" FontSize="13"
                         Foreground="#FF8B6914" VerticalAlignment="Center" HorizontalAlignment="Left"/>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <CheckBox Content="Эмоции" IsChecked="{Binding CollapseEmotionsNormal}" Margin="0,0,12,0" FontSize="11" VerticalAlignment="Center"/>
                <CheckBox Content="NodePID" IsChecked="{Binding CollapseNodePidNormal}" Margin="0,0,12,0" FontSize="11" VerticalAlignment="Center"/>
                <CheckBox Content="Триггер" IsChecked="{Binding CollapseTriggerNormal}" FontSize="11" VerticalAlignment="Center"/>
              </StackPanel>
            </Grid>
          </Border>
          <TreeView Grid.Row="1"
                    ItemsSource="{Binding TreeNormal}"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                    Margin="4"
                    BorderThickness="0">
            <TreeView.ItemContainerStyle>
              <Style TargetType="TreeViewItem">
                <Setter Property="IsExpanded">
                  <Setter.Value>
                    <MultiBinding Converter="{StaticResource EpisodicTreeExpandConverter}">
                      <Binding Path="Level"/>
                      <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.CollapseEmotionsNormal"/>
                      <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.CollapseNodePidNormal"/>
                      <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.CollapseTriggerNormal"/>
                    </MultiBinding>
                  </Setter.Value>
                </Setter>
              </Style>
            </TreeView.ItemContainerStyle>
          </TreeView>
        </Grid>
      </Border>

      <Border Grid.Column="2" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" Margin="3,0,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="#FFE8F5E9" Padding="8,6">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="Хорошо"
                         FontWeight="SemiBold" FontSize="13"
                         Foreground="#FF2E7D32" VerticalAlignment="Center" HorizontalAlignment="Left"/>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <CheckBox Content="Эмоции" IsChecked="{Binding CollapseEmotionsGood}" Margin="0,0,12,0" FontSize="11" VerticalAlignment="Center"/>
                <CheckBox Content="NodePID" IsChecked="{Binding CollapseNodePidGood}" Margin="0,0,12,0" FontSize="11" VerticalAlignment="Center"/>
                <CheckBox Content="Триггер" IsChecked="{Binding CollapseTriggerGood}" FontSize="11" VerticalAlignment="Center"/>
              </StackPanel>
            </Grid>
          </Border>
          <TreeView Grid.Row="1"
                    ItemsSource="{Binding TreeGood}"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                    Margin="4"
                    BorderThickness="0">
            <TreeView.ItemContainerStyle>
              <Style TargetType="TreeViewItem">
                <Setter Property="IsExpanded">
                  <Setter.Value>
                    <MultiBinding Converter="{StaticResource EpisodicTreeExpandConverter}">
                      <Binding Path="Level"/>
                      <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.CollapseEmotionsGood"/>
                      <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.CollapseNodePidGood"/>
                      <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.CollapseTriggerGood"/>
                    </MultiBinding>
                  </Setter.Value>
                </Setter>
              </Style>
            </TreeView.ItemContainerStyle>
          </TreeView>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
