<UserControl x:Class="AIStudio.Pages.ThinkingCyclesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:AIStudio.Converters"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1100">

  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

    <Style x:Key="CardBorderStyle" TargetType="Border">
      <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Background" Value="#FFF5F5F5"/>
    </Style>

    <Style x:Key="KeyTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#FF333333"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Margin" Value="0,0,10,4"/>
    </Style>

    <Style x:Key="ValueTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#FF0066B3"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="MonoReadOnlyTextBoxStyle" TargetType="TextBox">
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="6"/>
      <Setter Property="IsReadOnly" Value="True"/>
      <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
      <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
      <Setter Property="TextWrapping" Value="NoWrap"/>
    </Style>

    <Style x:Key="TileButtonStyle" TargetType="Button">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="2"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0"
                 Text="Циклы осмысления"
                 FontSize="18"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center"
                 Foreground="#FF333333"
                 Margin="0,0,0,6"/>

      <Border Grid.Row="1"
              BorderBrush="#FFE0E0E0"
              BorderThickness="1"
              CornerRadius="4"
              Padding="8,6"
              Background="#FFF5F5F5"
              Margin="0,0,0,10">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="Лимит фоновых циклов:" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <ComboBox Width="80"
                    Height="26"
                    ItemsSource="{Binding BackgroundLimitOptions}"
                    SelectedValue="{Binding SelectedBackgroundLimit}"
                    DisplayMemberPath="Value"
                    SelectedValuePath="Key"/>
          <TextBlock Text="{Binding BackgroundCountText}"
                     VerticalAlignment="Center"
                     Margin="16,0,0,0"
                     Foreground="#FF555555"/>
        </StackPanel>
      </Border>

      <Grid Grid.Row="2" MinHeight="400">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- Левая колонка не тянется по высоте правой (детали), иначе ScrollViewer даёт «пустоту» над плашками. -->
        <Border Grid.Column="0"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,10,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="900">
            <StackPanel Margin="8">
              <TextBlock Text="Главный цикл"
                         FontWeight="SemiBold"
                         Foreground="#FF333333"
                         Margin="0,0,0,4"
                         Visibility="{Binding HasMainCycle, Converter={StaticResource BoolToVis}}"/>

              <Button Style="{StaticResource TileButtonStyle}"
                      HorizontalAlignment="Stretch"
                      MinHeight="35"
                      DataContext="{Binding MainTile}"
                      Command="{Binding SelectCycleCommand}"
                      CommandParameter="{Binding CycleId}"
                      ToolTip="{Binding TooltipText}"
                      Visibility="{Binding DataContext.HasMainCycle, RelativeSource={RelativeSource AncestorType=StackPanel, Mode=FindAncestor}, Converter={StaticResource BoolToVis}}">
                <Border HorizontalAlignment="Stretch"
                        BorderBrush="{Binding SelectionBorderBrush}"
                        BorderThickness="{Binding SelectionBorderThickness}"
                        CornerRadius="4">
                  <Border HorizontalAlignment="Stretch"
                          BorderBrush="{Binding BorderBrush}"
                          BorderThickness="{Binding BorderThickness}"
                          CornerRadius="3"
                          Background="{Binding TileBackground}">
                    <Grid MinHeight="35">
                      <TextBlock Text="{Binding OrderLabel}"
                                 FontSize="15"
                                 FontWeight="Bold"
                                 Foreground="White"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </Border>
              </Button>

              <TextBlock Text="Фоновые циклы (ряды по диапазонам веса)"
                         FontWeight="SemiBold"
                         Foreground="#FF333333"
                         Margin="0,12,0,6"/>

              <TextBlock Text="Нет фоновых циклов"
                         Foreground="#FF777777"
                         FontStyle="Italic"
                         Visibility="{Binding HasBackgroundRows, Converter={StaticResource InverseBoolToVis}}"/>

              <ItemsControl ItemsSource="{Binding BackgroundRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Margin="0,6,0,0">
                      <TextBlock Text="{Binding WeightLabel}"
                                 FontSize="11"
                                 Foreground="#FF666666"
                                 Margin="0,0,0,4"/>
                      <ItemsControl ItemsSource="{Binding Tiles}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Button Style="{StaticResource TileButtonStyle}"
                                    Command="{Binding SelectCycleCommand}"
                                    CommandParameter="{Binding CycleId}"
                                    ToolTip="{Binding TooltipText}">
                              <Border HorizontalAlignment="Stretch"
                                      BorderBrush="{Binding SelectionBorderBrush}"
                                      BorderThickness="{Binding SelectionBorderThickness}"
                                      CornerRadius="4">
                                <Border HorizontalAlignment="Stretch"
                                        BorderBrush="{Binding BorderBrush}"
                                        BorderThickness="{Binding BorderThickness}"
                                        CornerRadius="3"
                                        Background="{Binding TileBackground}">
                                  <Grid MinWidth="29" MinHeight="24">
                                    <TextBlock Text="{Binding OrderLabel}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#FF1A1A1A"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                  </Grid>
                                </Border>
                              </Border>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
          <Grid Margin="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding DetailHeaderText}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#FF333333"
                       Margin="0,0,0,8"/>

            <Grid Grid.Row="1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Text="Id:" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetailIdText}" Style="{StaticResource ValueTextStyle}"/>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Order:" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DetailOrderText}" Style="{StaticResource ValueTextStyle}"/>

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Главный:" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DetailMainText}" Style="{StaticResource ValueTextStyle}"/>

              <TextBlock Grid.Row="3" Grid.Column="0" Text="Вес:" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DetailWeightText}" Style="{StaticResource ValueTextStyle}"/>

              <TextBlock Grid.Row="4" Grid.Column="0" Text="Шаги:" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DetailStepsText}" Style="{StaticResource ValueTextStyle}"/>

              <TextBlock Grid.Row="5" Grid.Column="0" Text="Создан на пульсе:" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DetailPulseText}" Style="{StaticResource ValueTextStyle}"/>

              <TextBlock Grid.Row="6" Grid.Column="0" Text="Обновлён:" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding DetailUpdatedText}" Style="{StaticResource ValueTextStyle}"/>

              <TextBlock Grid.Row="7" Grid.Column="0" Text="Ожидание автоматизма решения (ID):" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding DetailPendingAtmzText}" Style="{StaticResource ValueTextStyle}"/>

              <TextBlock Grid.Row="8" Grid.Column="0" Text="Ожид. оценки:" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding DetailAwaitingText}" Style="{StaticResource ValueTextStyle}"/>

              <TextBlock Grid.Row="9" Grid.Column="0" Text="Node / Problem / Theme / Purpose:" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding DetailContextLine}" Style="{StaticResource ValueTextStyle}"/>

              <TextBlock Grid.Row="10" Grid.Column="0" Text="Стратегия:" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding DetailStrategyText}" Style="{StaticResource ValueTextStyle}"/>

              <TextBlock Grid.Row="11" Grid.Column="0" Text="Ментальная цепочка (ИФ):" Style="{StaticResource KeyTextStyle}"/>
              <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding DetailMentalChainText}" Style="{StaticResource ValueTextStyle}"/>
            </Grid>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Row="3"
              Style="{StaticResource CardBorderStyle}"
              Margin="0,10,0,0">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0"
                     Text="История цикла"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="#FF333333"
                     Margin="0,0,0,6"/>
          <TextBox Grid.Row="1"
                   Style="{StaticResource MonoReadOnlyTextBoxStyle}"
                   Text="{Binding DetailLogText, Mode=OneWay}"
                   MinHeight="110"
                   MaxHeight="110"/>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
