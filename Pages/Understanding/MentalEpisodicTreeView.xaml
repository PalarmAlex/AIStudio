<UserControl x:Class="AIStudio.Pages.Understanding.MentalEpisodicTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:AIStudio.ViewModels.Understanding"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="1000">

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="{Binding CurrentAgentTitle}"
               FontSize="18"
               FontWeight="SemiBold"
               HorizontalAlignment="Center"
               Margin="0,0,0,5"
               Foreground="#FF333333"/>

    <TextBlock Grid.Row="1"
               HorizontalAlignment="Left"
               Margin="0,0,0,10"
               Foreground="#FF333333"
               TextWrapping="Wrap">
      <Run Text="{Binding CurrentAgentDescription.Text}"/>
      <Hyperlink Command="{Binding CurrentAgentDescription.OpenLinkCommand}">
        <Run Text="{Binding CurrentAgentDescription.LinkText}"/>
      </Hyperlink>
    </TextBlock>

    <Border Grid.Row="2"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1"
            CornerRadius="4"
            Margin="0,0,0,10"
            Padding="5"
            Background="#FFF5F5F5">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="Фильтры:"
                   VerticalAlignment="Top"
                   Margin="0,6,12,0"
                   FontWeight="Bold"/>

        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
          <StackPanel Orientation="Vertical" Margin="0,0,5,0" Width="120">
            <TextBlock Text="NodePID" FontSize="12" Margin="0,0,0,2"/>
            <TextBox Style="{StaticResource AgentFilterTextBoxStyle}"
                     Text="{Binding FilterNodePidInput, UpdateSourceTrigger=PropertyChanged}"
                     Height="25" Width="120"
                     ToolTip="Вхождение в ID узла дерева проблем (пусто = все)"/>
          </StackPanel>
          <StackPanel Orientation="Vertical" Margin="0,0,5,0" Width="120">
            <TextBlock Text="ThemeID" FontSize="12" Margin="0,0,0,2"/>
            <TextBox Style="{StaticResource AgentFilterTextBoxStyle}"
                     Text="{Binding FilterThemeIdInput, UpdateSourceTrigger=PropertyChanged}"
                     Height="25" Width="120"
                     ToolTip="Вхождение в ID образа темы"/>
          </StackPanel>
          <StackPanel Orientation="Vertical" Margin="0,0,5,0" Width="120">
            <TextBlock Text="PurposeID" FontSize="12" Margin="0,0,0,2"/>
            <TextBox Style="{StaticResource AgentFilterTextBoxStyle}"
                     Text="{Binding FilterPurposeIdInput, UpdateSourceTrigger=PropertyChanged}"
                     Height="25" Width="120"
                     ToolTip="Вхождение в ID образа цели"/>
          </StackPanel>
          <StackPanel Orientation="Vertical" Margin="0,0,5,0" Width="120">
            <TextBlock Text="Effect" FontSize="12" Margin="0,0,0,2"/>
            <TextBox Style="{StaticResource AgentFilterTextBoxStyle}"
                     Text="{Binding FilterEffectInput, UpdateSourceTrigger=PropertyChanged}"
                     Height="25" Width="120"
                     ToolTip="Вхождение в число эффекта (для правил)"/>
          </StackPanel>
          <StackPanel Orientation="Vertical" Margin="0,0,3,0" Width="120">
            <TextBlock Text="Цепочка ИФ" FontSize="12" Margin="0,0,0,2"/>
            <TextBox Style="{StaticResource AgentFilterTextBoxStyle}"
                     Text="{Binding FilterChainInput, UpdateSourceTrigger=PropertyChanged}"
                     Height="25" Width="120"
                     ToolTip="Подстрока в списке id через запятую"/>
          </StackPanel>
          <StackPanel Orientation="Vertical" Margin="0,0,5,0" Width="125">
            <TextBlock Text="Контекстов макс." FontSize="12" Margin="0,0,0,2"/>
            <ComboBox Style="{StaticResource AgentComboBoxStyle}"
                      ItemsSource="{Binding MaxContextsOptions}"
                      SelectedValue="{Binding SelectedMaxContexts, Mode=TwoWay}"
                      DisplayMemberPath="Value"
                      SelectedValuePath="Key"
                      Height="25" Width="120" Margin="0,0,0,0"/>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Top" Margin="5,0,0,0">
          <Button Content="Применить"
                  Command="{Binding ApplyFiltersCommand}"
                  Style="{StaticResource AgentButtonStyle}"
                  Margin="0,5,0,6"
                  Height="30"
                  Width="120"
                  Cursor="Hand"
                  HorizontalAlignment="Left"/>
          <Button Content="Сбросить"
                  Command="{Binding ClearFiltersCommand}"
                  Style="{StaticResource AgentButtonStyle}"
                  Height="30"
                  Width="120"
                  Cursor="Hand"
                  HorizontalAlignment="Left"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="3" Margin="0,0,0,5">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="220"/>
        <ColumnDefinition Width="400"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,0,5,0">
        <TreeView x:Name="MentalTree"
                  ItemsSource="{Binding TreeItems}"
                  SelectedItemChanged="MentalTree_SelectedItemChanged"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  Margin="4"
                  BorderThickness="0">
          <TreeView.ItemTemplate>
            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
              <TextBlock Text="{Binding TextDisplay}"
                         TextTrimming="CharacterEllipsis"
                         Margin="0,1"/>
            </HierarchicalDataTemplate>
          </TreeView.ItemTemplate>
        </TreeView>
      </Border>

      <Border Grid.Column="1" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" Margin="5,0,0,0"
              Background="#FFF9F9F9" Padding="10">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="Свойства узла"
                     FontSize="13" FontWeight="SemiBold" Foreground="#FF333333" Margin="0,0,0,8"/>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding SelectedNodePropertyRows}" VerticalAlignment="Top">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:PropertyRow}">
                  <Grid Margin="0,3,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontSize="12" Foreground="#FF333333" VerticalAlignment="Top">
                      <Run Text="{Binding Label}" FontWeight="Bold"/><Run Text=":"/>
                    </TextBlock>
                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12" Foreground="#FF0066B3"
                               TextWrapping="Wrap" VerticalAlignment="Top" Margin="4,0,0,0"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
