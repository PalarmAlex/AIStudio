<UserControl x:Class="AIStudio.Pages.Understanding.SituationTypesView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AIStudio.Pages.Understanding"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="950">

  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <Style x:Key="BaseTextBlockStyle" TargetType="TextBlock">
      <Setter Property="Background" Value="White"/>
      <Style.Triggers>
        <Trigger Property="Validation.HasError" Value="true">
          <Setter Property="Background" Value="#FFFDE6E6"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BaseTextBoxStyle" TargetType="TextBox">
      <Setter Property="Background" Value="White"/>
      <Style.Triggers>
        <Trigger Property="Validation.HasError" Value="true">
          <Setter Property="Background" Value="#FFFDE6E6"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Margin="12">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Заголовок -->
      <TextBlock Grid.Row="0"
                 Text="{Binding CurrentAgentTitle}"
                 FontSize="18"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,5"
                 Foreground="#FF333333"/>

      <TextBlock Grid.Row="1"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,10"
                 Foreground="#FF333333"
                 TextWrapping="Wrap"
                 Height="Auto">
        <Run Text="{Binding CurrentAgentDescription.Text}"/>
        <Hyperlink Command="{Binding CurrentAgentDescription.OpenLinkCommand}">
          <Run Text="{Binding CurrentAgentDescription.LinkText}"/>
        </Hyperlink>
      </TextBlock>

      <!-- Три таблицы: События | Настроение | Воздействие -->
      <Grid Grid.Row="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="5"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="5"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: События (1–20) с привязкой темы -->
        <Grid Grid.Column="0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0"
                     Text="Слоты событий (ID 1–20)"
                     FontWeight="SemiBold"
                     Margin="0,0,0,4"/>

          <Border Grid.Row="1"
                  BorderBrush="#FFE0E0E0"
                  BorderThickness="1"
                  CornerRadius="4"
                  Margin="0,0,0,0">
            <DataGrid ItemsSource="{Binding EventRecords}"
                      x:Name="EventGrid"
                      IsEnabled="True"
                      IsReadOnly="{Binding IsReadOnlyMode}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="#FFF9F9F9"
                      AlternatingRowBackground="White"
                      GridLinesVisibility="None"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HeadersVisibility="Column"
                      RowEditEnding="DataGrid_RowEditEnding"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
              <DataGrid.Columns>
                <DataGridTemplateColumn Header="Событие"
                                        Width="160"
                                        MinWidth="120">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <ComboBox ItemsSource="{Binding DataContext.EventAgentCellOptions, ElementName=Root}"
                                SelectedValue="{Binding EventAgentCode, UpdateSourceTrigger=PropertyChanged}"
                                DisplayMemberPath="Value"
                                SelectedValuePath="Key"
                                Height="24"
                                IsEnabled="{Binding DataContext.IsEditingEnabled, ElementName=Root}"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Тема"
                                        Width="*"
                                        MinWidth="180">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <ComboBox ItemsSource="{Binding DataContext.ThemeSlotCellOptions, ElementName=Root}"
                                SelectedValue="{Binding ThemeTypeId, UpdateSourceTrigger=PropertyChanged}"
                                DisplayMemberPath="Value"
                                SelectedValuePath="Key"
                                Height="24"
                                IsEnabled="{Binding DataContext.IsEditingEnabled, ElementName=Root}"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </Grid>

        <!-- Средняя панель: MoodId (21–40) -->
        <Grid Grid.Column="2">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0"
                     Text="Слоты настроения (ID 21–40)"
                     FontWeight="SemiBold"
                     Margin="0,0,0,4"/>

          <Border Grid.Row="1"
                  BorderBrush="#FFE0E0E0"
                  BorderThickness="1"
                  CornerRadius="4"
                  Margin="0,0,0,0">
            <DataGrid ItemsSource="{Binding MoodRecords}"
                      x:Name="MoodGrid"
                      IsEnabled="True"
                      IsReadOnly="{Binding IsReadOnlyMode}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="#FFF9F9F9"
                      AlternatingRowBackground="White"
                      GridLinesVisibility="None"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HeadersVisibility="Column"
                      RowEditEnding="DataGrid_RowEditEnding"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
              <DataGrid.Columns>
                <DataGridTemplateColumn Header="Настроение"
                                        Width="120">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <ComboBox ItemsSource="{Binding DataContext.MoodCellOptions, ElementName=Root}"
                                SelectedValue="{Binding MoodId, UpdateSourceTrigger=PropertyChanged}"
                                DisplayMemberPath="Value"
                                SelectedValuePath="Key"
                                Height="24"
                                IsEnabled="{Binding DataContext.IsEditingEnabled, ElementName=Root}"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Тема"
                                        Width="*"
                                        MinWidth="140">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <ComboBox ItemsSource="{Binding DataContext.ThemeSlotCellOptions, ElementName=Root}"
                                SelectedValue="{Binding ThemeTypeId, UpdateSourceTrigger=PropertyChanged}"
                                DisplayMemberPath="Value"
                                SelectedValuePath="Key"
                                Height="24"
                                IsEnabled="{Binding DataContext.IsEditingEnabled, ElementName=Root}"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </Grid>

        <!-- Правая панель: воздействие (ID 41–60) -->
        <Grid Grid.Column="4">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0"
                     Text="Слоты воздействия (ID 41–60)"
                     FontWeight="SemiBold"
                     Margin="0,0,0,4"/>

          <Border Grid.Row="1"
                  BorderBrush="#FFE0E0E0"
                  BorderThickness="1"
                  CornerRadius="4"
                  Margin="0,0,0,0">
            <DataGrid ItemsSource="{Binding InfluenceRecords}"
                      x:Name="InfluenceGrid"
                      IsEnabled="True"
                      IsReadOnly="{Binding IsReadOnlyMode}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="#FFF9F9F9"
                      AlternatingRowBackground="White"
                      GridLinesVisibility="None"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HeadersVisibility="Column"
                      RowEditEnding="DataGrid_RowEditEnding"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
              <DataGrid.Columns>
                <DataGridTemplateColumn Header="Воздействие"
                                        Width="120">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <ComboBox ItemsSource="{Binding DataContext.InfluenceCellOptions, ElementName=Root}"
                                SelectedValue="{Binding InfluenceId, UpdateSourceTrigger=PropertyChanged}"
                                DisplayMemberPath="Value"
                                SelectedValuePath="Key"
                                Height="24"
                                IsEnabled="{Binding DataContext.IsEditingEnabled, ElementName=Root}"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Тема"
                                        Width="*"
                                        MinWidth="140">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <ComboBox ItemsSource="{Binding DataContext.ThemeSlotCellOptions, ElementName=Root}"
                                SelectedValue="{Binding ThemeTypeId, UpdateSourceTrigger=PropertyChanged}"
                                DisplayMemberPath="Value"
                                SelectedValuePath="Key"
                                Height="24"
                                IsEnabled="{Binding DataContext.IsEditingEnabled, ElementName=Root}"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </Grid>
      </Grid>

      <!-- Нижняя строка: предупреждение слева, кнопки справа (как ThemeTypesView) -->
      <Border Grid.Row="3"
              BorderBrush="#FFE0E0E0"
              BorderThickness="0,1,0,0"
              Margin="0,8,0,0"
              Padding="0,6,0,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Column="0"
                     Text="{Binding PulseWarningMessage}"
                     Foreground="{Binding WarningMessageColor}"
                     FontStyle="Italic"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsEditingEnabled}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">
            <Button Content="Очистить"
                    Command="{Binding ClearAllCommand}"
                    PreviewMouseLeftButtonDown="SaveButton_PreviewMouseLeftButtonDown"
                    IsEnabled="{Binding IsEditingEnabled}"
                    Visibility="{Binding IsEditingEnabled, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource RedButtonStyle}"
                    ToolTip="Очистить привязки по всем слотам (см. текст подтверждения)"
                    Margin="0,0,8,0"/>
            <Button Content="Сохранить"
                    Command="{Binding SaveAllCommand}"
                    PreviewMouseLeftButtonDown="SaveButton_PreviewMouseLeftButtonDown"
                    IsEnabled="{Binding IsEditingEnabled}"
                    Visibility="{Binding IsEditingEnabled, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource ActionButtonStyle}"
                    ToolTip="Сохранить все слоты (1–60)"
                    Cursor="Hand"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>