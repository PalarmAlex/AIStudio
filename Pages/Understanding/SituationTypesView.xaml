<UserControl x:Class="AIStudio.Pages.Understanding.SituationTypesView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AIStudio.Pages.Understanding"
             xmlns:converters="clr-namespace:AIStudio.Converters"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="950">

  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <converters:SituationEventCodeDisplayConverter x:Key="SituationEventCodeDisplayConverter"/>
    <converters:SituationMoodIdDisplayConverter x:Key="SituationMoodIdDisplayConverter"/>
    <converters:SituationInfluenceIdDisplayConverter x:Key="SituationInfluenceIdDisplayConverter"/>
    <converters:ThemeTypeIdSituationTooltipConverter x:Key="ThemeTypeIdSituationTooltipConverter"/>

    <Style x:Key="BaseTextBlockStyle" TargetType="TextBlock">
      <Setter Property="Background" Value="White"/>
      <Style.Triggers>
        <Trigger Property="Validation.HasError" Value="true">
          <Setter Property="Background" Value="#FFFDE6E6"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SituationReadOnlyTextCellStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Padding" Value="2,0"/>
      <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
    </Style>

    <Style x:Key="BaseTextBoxStyle" TargetType="TextBox">
      <Setter Property="Background" Value="White"/>
      <Style.Triggers>
        <Trigger Property="Validation.HasError" Value="true">
          <Setter Property="Background" Value="#FFFDE6E6"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Margin="8">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Заголовок -->
      <TextBlock Grid.Row="0"
                 Text="{Binding CurrentAgentTitle}"
                 FontSize="18"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,2"
                 Foreground="#FF333333"/>

      <TextBlock Grid.Row="1"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,3"
                 Foreground="#FF333333"
                 TextWrapping="Wrap"
                 Height="Auto">
        <Run Text="{Binding CurrentAgentDescription.Text}"/>
        <Hyperlink Command="{Binding CurrentAgentDescription.OpenLinkCommand}">
          <Run Text="{Binding CurrentAgentDescription.LinkText}"/>
        </Hyperlink>
      </TextBlock>

      <!-- Три таблицы: События | Настроение | Воздействие -->
      <Grid Grid.Row="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="5"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="5"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: События (1–20) с привязкой темы -->
        <Grid Grid.Column="0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0"
                     Text="Слоты событий (ID 1–20)"
                     FontWeight="SemiBold"
                     Margin="0,0,0,1"/>

          <Border Grid.Row="1"
                  BorderBrush="#FFE0E0E0"
                  BorderThickness="1"
                  CornerRadius="4"
                  Margin="0,0,0,0"
                  Background="White">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Grid Grid.Row="0" Background="#FFF9F9F9" MinHeight="22">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="160" MinWidth="120"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Событие" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,1,2,1"/>
                <TextBlock Grid.Column="1" Text="Тема" FontWeight="SemiBold" VerticalAlignment="Center" Margin="2,1,4,1"/>
              </Grid>
              <ItemsControl Grid.Row="1"
                            ItemsSource="{Binding EventRecords}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="1,0" BorderBrush="#FFE8E8E8" BorderThickness="0,0,0,1" Background="#FFF9F9F9">
                      <Grid MinHeight="22">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="160" MinWidth="120"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource SituationReadOnlyTextCellStyle}"
                                   Text="{Binding EventAgentCode, Converter={StaticResource SituationEventCodeDisplayConverter}}"
                                   Focusable="False"/>
                        <ComboBox Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Margin="2,0,0,0"
                                  ItemsSource="{Binding DataContext.ThemeSlotCellOptions, ElementName=Root}"
                                  SelectedValue="{Binding ThemeTypeId, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="Value"
                                  SelectedValuePath="Key"
                                  Height="22"
                                  ToolTip="{Binding ThemeTypeId, Converter={StaticResource ThemeTypeIdSituationTooltipConverter}}"
                                  IsEnabled="{Binding DataContext.IsEditingEnabled, ElementName=Root}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </Border>
        </Grid>

        <!-- Средняя панель: MoodId (21–40) -->
        <Grid Grid.Column="2">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0"
                     Text="Слоты настроения (ID 21–40)"
                     FontWeight="SemiBold"
                     Margin="0,0,0,1"/>

          <Border Grid.Row="1"
                  BorderBrush="#FFE0E0E0"
                  BorderThickness="1"
                  CornerRadius="4"
                  Margin="0,0,0,0"
                  Background="White">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Grid Grid.Row="0" Background="#FFF9F9F9" MinHeight="22">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Настроение" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,1,2,1"/>
                <TextBlock Grid.Column="1" Text="Тема" FontWeight="SemiBold" VerticalAlignment="Center" Margin="2,1,4,1"/>
              </Grid>
              <ItemsControl Grid.Row="1"
                            ItemsSource="{Binding MoodRecords}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="1,0" BorderBrush="#FFE8E8E8" BorderThickness="0,0,0,1" Background="#FFF9F9F9">
                      <Grid MinHeight="22">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="120"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource SituationReadOnlyTextCellStyle}"
                                   Text="{Binding MoodId, Converter={StaticResource SituationMoodIdDisplayConverter}}"
                                   Focusable="False"/>
                        <ComboBox Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Margin="2,0,0,0"
                                  ItemsSource="{Binding DataContext.ThemeSlotCellOptions, ElementName=Root}"
                                  SelectedValue="{Binding ThemeTypeId, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="Value"
                                  SelectedValuePath="Key"
                                  Height="22"
                                  ToolTip="{Binding ThemeTypeId, Converter={StaticResource ThemeTypeIdSituationTooltipConverter}}"
                                  IsEnabled="{Binding DataContext.IsEditingEnabled, ElementName=Root}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </Border>
        </Grid>

        <!-- Правая панель: воздействие (ID 41–60) -->
        <Grid Grid.Column="4">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0"
                     Text="Слоты воздействия (ID 41–60)"
                     FontWeight="SemiBold"
                     Margin="0,0,0,1"/>

          <Border Grid.Row="1"
                  BorderBrush="#FFE0E0E0"
                  BorderThickness="1"
                  CornerRadius="4"
                  Margin="0,0,0,0"
                  Background="White">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Grid Grid.Row="0" Background="#FFF9F9F9" MinHeight="22">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Воздействие" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,1,2,1"/>
                <TextBlock Grid.Column="1" Text="Тема" FontWeight="SemiBold" VerticalAlignment="Center" Margin="2,1,4,1"/>
              </Grid>
              <ItemsControl Grid.Row="1"
                            ItemsSource="{Binding InfluenceRecords}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="1,0" BorderBrush="#FFE8E8E8" BorderThickness="0,0,0,1" Background="#FFF9F9F9">
                      <Grid MinHeight="22">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="120"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource SituationReadOnlyTextCellStyle}"
                                   Text="{Binding InfluenceId, Converter={StaticResource SituationInfluenceIdDisplayConverter}}"
                                   Focusable="False"/>
                        <ComboBox Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Margin="2,0,0,0"
                                  ItemsSource="{Binding DataContext.ThemeSlotCellOptions, ElementName=Root}"
                                  SelectedValue="{Binding ThemeTypeId, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="Value"
                                  SelectedValuePath="Key"
                                  Height="22"
                                  ToolTip="{Binding ThemeTypeId, Converter={StaticResource ThemeTypeIdSituationTooltipConverter}}"
                                  IsEnabled="{Binding DataContext.IsEditingEnabled, ElementName=Root}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </Border>
        </Grid>
      </Grid>

      <!-- Нижняя строка: предупреждение слева, кнопки справа (как ThemeTypesView) -->
      <Border Grid.Row="3"
              BorderBrush="#FFE0E0E0"
              BorderThickness="0,1,0,0"
              Margin="0,4,0,0"
              Padding="0,3,0,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Column="0"
                     Text="{Binding PulseWarningMessage}"
                     Foreground="{Binding WarningMessageColor}"
                     FontStyle="Italic"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsEditingEnabled}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">
            <Button Content="Заполнить"
                    Command="{Binding FillDefaultsCommand}"
                    PreviewMouseLeftButtonDown="SaveButton_PreviewMouseLeftButtonDown"
                    IsEnabled="{Binding IsEditingEnabled}"
                    Visibility="{Binding IsEditingEnabled, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource ActionButtonStyle}"
                    ToolTip="Подставить рекомендуемые коды событий и темы (слоты 1–8) и настроение с темами (слоты 21–28) из дефолтов движка. Слоты воздействия не меняются. Сохранение в файл — кнопкой «Сохранить»."
                    Margin="0,0,8,0"
                    Cursor="Hand"/>
            <Button Content="Очистить"
                    Command="{Binding ClearAllCommand}"
                    PreviewMouseLeftButtonDown="SaveButton_PreviewMouseLeftButtonDown"
                    IsEnabled="{Binding IsEditingEnabled}"
                    Visibility="{Binding IsEditingEnabled, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource RedButtonStyle}"
                    ToolTip="Очистить привязки по всем слотам (см. текст подтверждения)"
                    Margin="0,0,8,0"/>
            <Button Content="Сохранить"
                    Command="{Binding SaveAllCommand}"
                    PreviewMouseLeftButtonDown="SaveButton_PreviewMouseLeftButtonDown"
                    IsEnabled="{Binding IsEditingEnabled}"
                    Visibility="{Binding IsEditingEnabled, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource ActionButtonStyle}"
                    ToolTip="Сохранить все слоты (1–60)"
                    Cursor="Hand"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>