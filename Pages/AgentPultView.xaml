<UserControl x:Class="AIStudio.Pages.AgentPultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AIStudio.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="900">

  <UserControl.Resources>
    <Style x:Key="PropertyNameStyle" TargetType="TextBlock">
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Margin" Value="0,0,0,5"/>
      <Setter Property="Width" Value="200"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="EditableFieldStyle" TargetType="TextBox">
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="MinWidth" Value="350"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#FF7F9DB9"/>
      <Setter Property="Padding" Value="2"/>
    </Style>

    <Style x:Key="RecognitionTextStyle" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Courier New"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="DarkRed"/>
      <Setter Property="Background" Value="#FFF8F8F8"/>
      <Setter Property="Padding" Value="5"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="ChainPanelStyle" TargetType="StackPanel">
      <Setter Property="Margin" Value="0,5,0,0"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style x:Key="ProbePressureToggleStyle" TargetType="ToggleButton">
      <Setter Property="Width" Value="18"/>
      <Setter Property="Height" Value="16"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Background" Value="#FFECEFF1"/>
      <Setter Property="BorderBrush" Value="#FF90A4AE"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Style.Triggers>
        <Trigger Property="IsChecked" Value="True">
          <Setter Property="Background" Value="#FF2E7D32"/>
          <Setter Property="Foreground" Value="White"/>
          <Setter Property="BorderBrush" Value="#FF1B5E20"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="ProbeReleaseToggleStyle" TargetType="ToggleButton">
      <Setter Property="Width" Value="18"/>
      <Setter Property="Height" Value="16"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Margin" Value="1,0,0,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Background" Value="#FFECEFF1"/>
      <Setter Property="BorderBrush" Value="#FF90A4AE"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Style.Triggers>
        <Trigger Property="IsChecked" Value="True">
          <Setter Property="Background" Value="#FFD32F2F"/>
          <Setter Property="Foreground" Value="White"/>
          <Setter Property="BorderBrush" Value="#FFB71C1C"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="ProbeResetButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="16"/>
      <Setter Property="Height" Value="16"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="1,0,0,0"/>
      <Setter Property="Foreground" Value="#FFD32F2F"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="ToolTip" Value="Сбросить выбор"/>
    </Style>
    <Style x:Key="ProbeSelectionRowBorderCompactStyle" TargetType="Border" BasedOn="{StaticResource ProbeSelectionRowBorderStyle}">
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Padding" Value="2,0"/>
      <Setter Property="Margin" Value="0,1"/>
    </Style>

  </UserControl.Resources>

  <Grid PreviewKeyDown="OnRootPreviewKeyDown">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="350"/>
      <ColumnDefinition Width="130.14"/>
      <ColumnDefinition Width="111.86"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="1.55*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition/>
    </Grid.RowDefinitions>

    <!-- Заголовки: Сообщение | Распознанные токены | Прямое воздействие | Через среду -->
    <TextBlock Grid.Column="0" Grid.Row="0" Text="Сообщение" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
    <TextBlock Grid.Column="1" Grid.Row="0" Text="Распознанные токены:" Style="{StaticResource PropertyNameStyle}" Margin="10,0,0,5" Grid.ColumnSpan="2"/>
    <TextBlock Grid.Column="3" Grid.Row="0" Text="Прямое воздействие" Style="{StaticResource PropertyNameStyle}" Margin="10,0,0,5" Width="200"/>
    <TextBlock Grid.Column="4" Grid.Row="0"
               Text="Через среду (вирт. тест)"
               Style="{StaticResource PropertyNameStyle}"
               Margin="10,0,0,5"
               ToolTip="Имитация метрики среды (как Velum): «+» — давление (фаза A), «−» — отпускание (возврат к норме). Без стимула с пульта."/>

    <!-- Окно речевого сообщения -->
    <TextBox x:Name="MessageToAgentTextBox" Grid.Row="1"
             Text="{Binding MessageText}"
             IsEnabled="True"
             Style="{StaticResource EditableFieldStyle}"
             Height="40"
             VerticalAlignment="Top"
             Width="350"
             ToolTip="Вербальный канал (побуквенные токены)"
             HorizontalAlignment="Center"/>

    <!-- Надпись "Команды" -->
    <TextBlock Grid.Column="0" Grid.Row="2" Text="Команды" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,5,0,3" FontWeight="Bold"/>

    <!-- Контейнер для выравнивания полей "Команды" и "Распознанные токены" -->
    <Grid Grid.Column="0" Grid.Row="3" VerticalAlignment="Top">
      <TextBox Text="{Binding CommandMessageText}"
               IsEnabled="True"
               Style="{StaticResource EditableFieldStyle}"
               Height="40"
               VerticalAlignment="Top"
               Width="350"
               ToolTip="Командный канал (атомарные контуры)"
               HorizontalAlignment="Center"/>
    </Grid>

    <!-- Отображение распознанного текста -->
    <Border Grid.Column="1" Grid.Row="1" Grid.RowSpan="3"
            BorderBrush="#FFCCCCCC" 
            BorderThickness="1" 
            Background="#FFF8F8F8" 
            Padding="10" 
            Margin="5,0,0,0" 
            VerticalAlignment="Top"
            Grid.ColumnSpan="2">
      <TextBlock Text="{Binding RecognitionDisplayText}" 
                 Style="{StaticResource RecognitionTextStyle}"
                 ToolTip="xxxxx — нераспознанные элементы" Height="88"/>
    </Border>

    <!-- Кол. 0: Режим наблюдения | Авторитарная запись -->
    <Grid Grid.Column="0" Grid.Row="4" Margin="0,10,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <CheckBox Grid.Column="0"
                Content="Режим наблюдения"
                IsChecked="{Binding ObservationMode}"
                ToolTip="Действия с пульта не оказывают влияния на гомеостаз симбионта, как будто он их наблюдает на другом"
                VerticalAlignment="Center" Margin="0,3,0,0"/>
      <CheckBox Grid.Column="1"
                Content="Авторитарная запись"
                IsChecked="{Binding AuthoritativeMode}"
                ToolTip="Новые фразы и команды сразу записываются в дерево, минуя песочницу"
                VerticalAlignment="Center"
                HorizontalAlignment="Right" Margin="0,3,0,0"/>
    </Grid>

    <!-- Кол. 0: Тон | Настроение -->
    <Grid Grid.Column="0" Grid.Row="5" Margin="0,8,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,12,0">
        <TextBlock Text="Тон" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14"/>
        <ComboBox ItemsSource="{Binding ToneList}"
                  SelectedValuePath="Key"
                  DisplayMemberPath="Value"
                  SelectedValue="{Binding SelectedToneId, UpdateSourceTrigger=PropertyChanged}"
                  MinWidth="100"
                  Height="25" Margin="10,0,0,0" Width="80"/>
      </StackPanel>
      <Grid Grid.Column="1" VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Text="Настроение"
                   VerticalAlignment="Center"
                   Margin="0,0,6,0"
                   FontSize="14"/>
        <ComboBox Grid.Column="1"
                  ItemsSource="{Binding MoodList}"
                  SelectedValuePath="Key"
                  DisplayMemberPath="Value"
                  SelectedValue="{Binding SelectedMoodId, UpdateSourceTrigger=PropertyChanged}"
                  MinWidth="80"
                  MaxWidth="110"
                  Height="25" HorizontalAlignment="Stretch"/>
      </Grid>
    </Grid>

    <!-- Кол. 0: Цвет -->
    <StackPanel Grid.Column="0" Grid.Row="6" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,5,0,0">
      <TextBlock Text="Цвет" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
      <ComboBox ItemsSource="{Binding VisualColorList}"
                SelectedValuePath="Key"
                DisplayMemberPath="Value"
                SelectedValue="{Binding SelectedVisualColorId, UpdateSourceTrigger=PropertyChanged}"
                MinWidth="100"
                Height="25"
                ToolTip="Зрительский канал пускового образа (0 — белый по умолчанию). Для компаундного CS используйте фразу + ненулевой цвет." Width="80"/>
    </StackPanel>

    <!-- Панель управления цепочкой (рефлексы — плашка с оценкой; автоматизмы — только надпись о звене) -->
    <StackPanel Grid.Column="1" Grid.Row="4" Grid.RowSpan="3"
                Style="{StaticResource ChainPanelStyle}"
                Orientation="Vertical" Width="230" Grid.ColumnSpan="2" HorizontalAlignment="Center">

      <!-- Индикатор активности цепочки рефлексов (плашка с оценкой) -->
      <Border BorderBrush="Gray" 
              BorderThickness="1" 
              Background="{Binding ChainActiveBackground}"
              Padding="5,2"
              Margin="5,0,0,2"
              Visibility="{Binding ChainControlVisibility}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse Width="10" Height="10" Fill="{Binding ChainActiveIndicatorColor}" Margin="0,0,5,0"/>
          <TextBlock Text="{Binding ChainActiveStatusWithId}" 
                     FontWeight="Bold" 
                     Foreground="{Binding ChainActiveTextColor}"/>
        </StackPanel>
      </Border>

      <!-- Надпись для цепочки автоматизмов (оценка — по эффекту стимула, плашка не используется) -->
      <TextBlock Text="{Binding AutomatizmChainStatusText}"
                 FontWeight="Bold"
                 Foreground="DarkGreen"
                 Margin="5,2,0,0"
                 VerticalAlignment="Center"
                 Visibility="{Binding AutomatizmChainStatusVisibility}"/>

      <!-- Переключатель успеха/неуспеха (только для цепочек рефлексов) -->
      <StackPanel Orientation="Horizontal" 
                  VerticalAlignment="Center"
                  Margin="0,5,0,0"
                  Visibility="{Binding ChainControlVisibility}">
        <TextBlock Text="Результат звена:" 
                   Margin="0,0,10,0" 
                   VerticalAlignment="Center"
                   ToolTip="Текущий результат выполнения действия в цепочке рефлексов"/>
        <RadioButton Content="Успех" 
                     IsChecked="{Binding ChainStepSuccess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     GroupName="ChainResult"
                     Margin="0,0,10,0"
                     ToolTip="Действие выполнено успешно"/>
        <RadioButton Content="Неудача" 
                     IsChecked="{Binding ChainStepFailure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     GroupName="ChainResult"
                     ToolTip="Действие не выполнено или выполнено с ошибкой"/>
      </StackPanel>
    </StackPanel>

    <!-- Окно воздействий: оператор + среда (по одному столбцу), вертикальный скролл -->
    <Grid Grid.Column="3" Grid.ColumnSpan="2" Grid.Row="1" Grid.RowSpan="8" Margin="10,0,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    MaxHeight="280">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.9*"/>
            <ColumnDefinition Width="1.1*" MinWidth="210"/>
          </Grid.ColumnDefinitions>

          <ItemsControl Grid.Column="0" ItemsSource="{Binding OperatorActions}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <CheckBox Content="{Binding Name}"
                          IsChecked="{Binding IsSelected}"
                          IsEnabled="{Binding IsEnabled}"
                          Margin="0,2"
                          ToolTip="{Binding Description}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <ItemsControl Grid.Column="1" ItemsSource="{Binding EnvironmentActions}" Margin="8,0,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Style="{StaticResource ProbeSelectionRowBorderCompactStyle}">
                  <Grid MinHeight="18">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Name}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               FontSize="12"
                               Margin="0,0,4,0"
                               ToolTip="{Binding Description}"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                      <ToggleButton Content="+"
                                    Style="{StaticResource ProbePressureToggleStyle}"
                                    IsChecked="{Binding IsPressure, Mode=TwoWay}"
                                    ToolTip="Давление метрики (+): сдвиг параметров, как при плохой метрике в Velum"/>
                      <ToggleButton Content="−"
                                    Style="{StaticResource ProbeReleaseToggleStyle}"
                                    IsChecked="{Binding IsRelease, Mode=TwoWay}"
                                    ToolTip="Отпускание метрики (−): возврат параметров к норме, как при улучшении метрики в Velum"/>
                      <Button Content="✕"
                              Style="{StaticResource ProbeResetButtonStyle}"
                              Click="ProbeReset_Click"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </ScrollViewer>

      <Button Grid.Row="2"
              Content="Отправить"
              Command="{Binding ApplyInfluenceCommand}"
              IsDefault="True"
              Style="{StaticResource ActionButtonStyle}"
              IsEnabled="{Binding IsEditingEnabled}"
              Height="30"
              MinWidth="100"
              Margin="0,10,0,0"
              VerticalAlignment="Center"
              HorizontalAlignment="Right"
              Cursor="Hand" Width="110"/>
    </Grid>

  </Grid>
</UserControl>