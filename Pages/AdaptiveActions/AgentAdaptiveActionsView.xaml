<UserControl x:Class="AIStudio.Pages.AgentAdaptiveActionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:AIStudio.Converters"
             mc:Ignorable="d"
             Height="Auto" Width="Auto"
             x:Name="Root">

  <UserControl.Resources>
    <converters:IsActiveActionMultiConverter x:Key="IsActiveActionMultiConverter"/>
    <converters:SignificanceConverter x:Key="SignificanceConverter"/>
    <converters:ActionSizeConverter x:Key="ActionSizeConverter"/>
    <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
    <converters:ActionDisplayTextConverter x:Key="ActionDisplayTextConverter"/>

    <Style x:Key="NoAdaptationTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#FFA0A0A0"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontStyle" Value="Italic"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
      <Setter Property="Margin" Value="5"/>
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#FF404040"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>

    <Style x:Key="ReflexWordsTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="DarkBlue"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="Padding" Value="5,5"/>
    </Style>

    <!-- Стиль для подписей «Тон», «Настроение», «Фраза» — серый, шрифт на 2 пункта меньше -->
    <Style x:Key="ReflexPhraseMetaStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="#FF808080"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <DataTemplate x:Key="ReflexPhraseBlockTemplate">
      <StackPanel Margin="0,4,0,0">
        <TextBlock Style="{StaticResource ReflexPhraseMetaStyle}">
          <Run Text="Тон: "/>
          <Run Text="{Binding ToneText}"/>
        </TextBlock>
        <TextBlock Style="{StaticResource ReflexPhraseMetaStyle}">
          <Run Text="Настроение: "/>
          <Run Text="{Binding MoodText}"/>
        </TextBlock>
        <StackPanel Orientation="Horizontal" Margin="0,2,0,0" VerticalAlignment="Center">
          <TextBlock Foreground="#FF808080" FontSize="14" Text="Фраза: " VerticalAlignment="Center"/>
          <TextBlock Text="{Binding PhraseText}"
                     FontSize="{Binding PhraseFontSize}"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="DarkBlue"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding UseGreenColor}" Value="True">
                    <Setter Property="Foreground" Value="Green"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <!-- Общий шаблон для отображения действий -->
    <DataTemplate x:Key="ActionItemTemplate">
      <Grid>
        <TextBlock x:Name="ActionText"
            Text="{Binding ., Converter={StaticResource ActionDisplayTextConverter}}"
            FontSize="{Binding ., Converter={StaticResource ActionSizeConverter}}"
            FontWeight="SemiBold"
            Margin="3,1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

          <TextBlock.Foreground>
            <MultiBinding Converter="{StaticResource IsActiveActionMultiConverter}">
              <Binding Path="DataContext.CurrentActiveActions" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
              <Binding Path="."/>
            </MultiBinding>
          </TextBlock.Foreground>

        </TextBlock>
      </Grid>
    </DataTemplate>

  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel>

      <!-- Таблица с четырьмя колонками -->
      <Grid Margin="0,5">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Колонка 1: Безусловные рефлексы -->
        <StackPanel Grid.Column="0" Grid.Row="0">
          <TextBlock Text="Безусловные рефлексы" Style="{StaticResource SectionHeaderStyle}"/>
        </StackPanel>

        <!-- Колонка 2: Условные рефлексы -->
        <StackPanel Grid.Column="1" Grid.Row="0">
          <TextBlock Text="Условные рефлексы" Style="{StaticResource SectionHeaderStyle}"/>
        </StackPanel>

        <!-- Колонка 3: Автоматизмы -->
        <StackPanel Grid.Column="2" Grid.Row="0">
          <TextBlock Text="Автоматизмы" Style="{StaticResource SectionHeaderStyle}"/>
        </StackPanel>

        <!-- Колонка 4: Ответные фразы -->
        <StackPanel Grid.Column="3" Grid.Row="0">
          <TextBlock Text="Ответные фразы" Style="{StaticResource SectionHeaderStyle}"/>
        </StackPanel>

        <!-- Колонка 1: Безусловные рефлексы -->
        <Border Grid.Column="0" Grid.Row="1" 
                BorderThickness="0,1,1,0" 
                BorderBrush="#FFE0E0E0" 
                Padding="5"
                Height="80">
          <StackPanel>
            <TextBlock Text="Нет безусловных рефлексов"
                  Style="{StaticResource NoAdaptationTextStyle}"
                  Visibility="{Binding GeneticReflexActions.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=true}"/>

            <ItemsControl ItemsSource="{Binding GeneticReflexActions}" ItemTemplate="{StaticResource ActionItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Колонка 2: Условные рефлексы -->
        <Border Grid.Column="1" Grid.Row="1" 
                BorderThickness="0,1,1,0" 
                BorderBrush="#FFE0E0E0" 
                Padding="5"
                Height="80">
          <StackPanel>
            <TextBlock Text="Нет условных рефлексов"
                  Style="{StaticResource NoAdaptationTextStyle}"
                  Visibility="{Binding ConditionedReflexActions.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=true}"/>

            <ItemsControl ItemsSource="{Binding ConditionedReflexActions}" ItemTemplate="{StaticResource ActionItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Колонка 4: Автоматизмы -->
        <Border Grid.Column="2" Grid.Row="1" 
                BorderThickness="0,1,1,0" 
                BorderBrush="#FFE0E0E0" 
                Padding="5"
                Height="80">
          <StackPanel>
            <TextBlock Text="Нет автоматизмов"
                  Style="{StaticResource NoAdaptationTextStyle}"
                  Visibility="{Binding AutomatizmActions.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=true}"/>

            <ItemsControl ItemsSource="{Binding AutomatizmActions}" ItemTemplate="{StaticResource ActionItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Колонка 3: Фразы агента -->
        <Border Grid.Column="3" Grid.Row="1" 
                BorderThickness="0,1,0,0" 
                BorderBrush="#FFE0E0E0" 
                Padding="5"
                Height="80">
          <Grid>
            <TextBlock Text="Нет ответных фраз"
                       Style="{StaticResource NoAdaptationTextStyle}"
                       Visibility="{Binding ReflexPhraseBlocksCount, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=true}"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding ReflexPhraseBlocks}"
                            ItemTemplate="{StaticResource ReflexPhraseBlockTemplate}"
                            Visibility="{Binding ReflexPhraseBlocksCount, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=Invert}"/>
            </ScrollViewer>
          </Grid>
        </Border>

      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>