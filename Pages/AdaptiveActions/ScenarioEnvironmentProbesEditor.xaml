<Window x:Class="AIStudio.Dialogs.ScenarioEnvironmentProbesEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:symbiontEnv="clr-namespace:AIStudio.Common.SymbiontEnv"
        mc:Ignorable="d"
        Height="480" Width="500"
        WindowStartupLocation="CenterOwner"
        MinHeight="360" MinWidth="420"
        ResizeMode="CanResizeWithGrip"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">

  <Window.Resources>
    <Style x:Key="InfoTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style x:Key="ProbePressureToggleStyle" TargetType="ToggleButton">
      <Setter Property="Width" Value="30"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Margin" Value="2,0"/>
      <Setter Property="Background" Value="#FFECEFF1"/>
      <Setter Property="BorderBrush" Value="#FF90A4AE"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Style.Triggers>
        <Trigger Property="IsChecked" Value="True">
          <Setter Property="Background" Value="#FF2E7D32"/>
          <Setter Property="Foreground" Value="White"/>
          <Setter Property="BorderBrush" Value="#FF1B5E20"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="ProbeReleaseToggleStyle" TargetType="ToggleButton">
      <Setter Property="Width" Value="30"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Margin" Value="2,0"/>
      <Setter Property="Background" Value="#FFECEFF1"/>
      <Setter Property="BorderBrush" Value="#FF90A4AE"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Style.Triggers>
        <Trigger Property="IsChecked" Value="True">
          <Setter Property="Background" Value="#FFD32F2F"/>
          <Setter Property="Foreground" Value="White"/>
          <Setter Property="BorderBrush" Value="#FFB71C1C"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="ProbeResetButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="24"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="4,0,0,0"/>
      <Setter Property="Foreground" Value="#FFD32F2F"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="ToolTip" Value="Сбросить выбор"/>
    </Style>
  </Window.Resources>

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="#FF2196F3"
            CornerRadius="4"
            Margin="0,0,0,10"
            Padding="10">
      <TextBlock x:Name="HeaderTitle"
                 Text="Воздействие от среды"
                 FontSize="16"
                 FontWeight="Bold"
                 HorizontalAlignment="Center"
                 Foreground="White"/>
    </Border>

    <TextBlock Grid.Row="1"
               Text="Выберите метрики среды и тип действия: «+» — давление, «−» — отпускание."
               Margin="0,0,0,8"
               TextWrapping="Wrap"
               Style="{StaticResource InfoTitleStyle}"
               Foreground="#FF0D47A1"/>

    <Border Grid.Row="2"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1"
            CornerRadius="4">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FFE8EAF6" BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1" Padding="8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="70"/>
              <ColumnDefinition Width="28"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="МЕТРИКА СРЕДЫ" FontWeight="Bold" FontSize="14" Foreground="#FF3F51B5"/>
            <TextBlock Grid.Column="1" Text="+ / −" FontWeight="Bold" FontSize="14" Foreground="#FF3F51B5" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="✕" FontWeight="Bold" FontSize="14" Foreground="#FFD32F2F" HorizontalAlignment="Center" ToolTip="Сброс выбора строки"/>
          </Grid>
        </Border>
        <ListBox Grid.Row="1"
                 x:Name="ProbesList"
                 Background="#FFF9F9F9"
                 BorderThickness="0">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
              <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                  <Setter Property="Background" Value="Transparent"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource ProbeSelectionRowBorderStyle}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding Name}"
                             VerticalAlignment="Center"
                             ToolTip="{Binding Description}"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ToggleButton Content="+"
                                  Style="{StaticResource ProbePressureToggleStyle}"
                                  IsChecked="{Binding IsPressure, Mode=TwoWay}"
                                  ToolTip="Давление метрики (+)"/>
                    <ToggleButton Content="−"
                                  Style="{StaticResource ProbeReleaseToggleStyle}"
                                  IsChecked="{Binding IsRelease, Mode=TwoWay}"
                                  ToolTip="Отпускание метрики (−)"/>
                  </StackPanel>
                  <Button Grid.Column="2"
                          Content="✕"
                          Style="{StaticResource ProbeResetButtonStyle}"
                          Click="ProbeReset_Click"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Border Grid.Row="3"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10"
            Margin="0,12,0,0"
            Background="#FFF5F5F5">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="OK" Width="100" Height="32" Margin="0,0,8,0"
                IsDefault="True" Click="OK_Click"
                Background="#FF4CAF50" BorderBrush="#FF388E3C" Foreground="White" FontWeight="SemiBold"/>
        <Button Content="Отмена" Width="100" Height="32" Click="Cancel_Click"
                Background="#FFF5F5F5" BorderBrush="#FF9E9E9E"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
