<UserControl x:Class="AIStudio.Pages.Research.ScenarioEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="EditorRoot"
        MinHeight="400">
  <UserControl.Resources>
    <Style x:Key="LinkDataGridStyle" TargetType="DataGrid">
      <Setter Property="Background" Value="White"/>
      <Setter Property="RowBackground" Value="#FFF9F9F9"/>
      <Setter Property="AlternatingRowBackground" Value="#FFF0F0F0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="GridLinesVisibility" Value="None"/>
      <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
      <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
      <Setter Property="SelectionUnit" Value="FullRow"/>
      <Setter Property="CanUserAddRows" Value="False"/>
      <Setter Property="CanUserDeleteRows" Value="False"/>
      <Setter Property="CanUserSortColumns" Value="False"/>
    </Style>
    <Style x:Key="HighlightedRowStyle" TargetType="DataGridRow">
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#FFE3F2FD"/>
          <Setter Property="BorderBrush" Value="#FF2196F3"/>
          <Setter Property="BorderThickness" Value="1"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="StageItemContainerStyle" TargetType="ComboBoxItem">
      <Setter Property="ToolTip" Value="{Binding Description}"/>
    </Style>
  </UserControl.Resources>
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" Content="← Назад к реестру" Padding="10,6" Margin="0,0,10,0"
              VerticalAlignment="Center" Click="BackButton_Click" Cursor="Hand"/>
      <Border Grid.Column="1"
              Background="#FF2196F3"
              CornerRadius="3"
              Padding="6,8" VerticalAlignment="Center">
        <TextBlock Text="РЕДАКТОР СЦЕНАРИЯ ОПЕРАТОРА"
                   FontSize="14"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="White"/>
      </Border>
    </Grid>

    <TabControl Grid.Row="1" Margin="0,0,0,4" Padding="0,4,0,0"
                VerticalContentAlignment="Stretch">
      <TabItem Header="Сведения">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="4">
          <StackPanel>
            <Border BorderBrush="#FFBBDEFB"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10,8"
                    Background="#FFE3F2FD">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                  <TextBlock Text="Дата" FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1" Margin="0,0,0,4"/>
                  <TextBox Text="{Binding DateText, UpdateSourceTrigger=PropertyChanged}" Padding="4,3" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                  <TextBlock Text="Название" FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1" Margin="0,0,0,4"/>
                  <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Padding="4,3" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,0">
                  <TextBlock Text="Описание" FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1" Margin="0,0,0,4"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="DescriptionTextBox"
                             Grid.Column="0"
                             Text="{Binding DescriptionDisplay, Mode=OneWay}"
                             IsReadOnly="True" Padding="4,3" FontSize="12"
                             Background="#FFF5F5F5"
                             ToolTip="{Binding Description}"/>
                    <Button Grid.Column="1" Content="Редактировать…" Padding="10,4" Margin="8,0,0,0"
                            VerticalAlignment="Center" Click="EditDescriptionButton_Click"/>
                  </Grid>
                </StackPanel>
              </Grid>
            </Border>

            <Border Margin="0,10,0,0" BorderBrush="#FFBBDEFB" BorderThickness="1" CornerRadius="4" Padding="10,8" Background="#FFE8EAF6">
              <StackPanel>
                <TextBlock Text="Выполнить действие перед запуском" FontSize="13" FontWeight="SemiBold" Foreground="#FF283593" Margin="0,0,0,8"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Перейти на стадию" VerticalAlignment="Center" Margin="0,0,12,8"
                             FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1"/>
                  <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Padding="4,3" FontSize="12" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding PreRunStageChoices}"
                              SelectedValue="{Binding PreRunTargetStage, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="StageNumber"
                              DisplayMemberPath="Description"
                              ItemContainerStyle="{StaticResource StageItemContainerStyle}"/>
                  </Grid>
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Коэфф. пульсации" VerticalAlignment="Center" Margin="0,0,12,8"
                             FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1"/>
                  <ComboBox Grid.Row="1" Grid.Column="1" Padding="4,3" FontSize="12" HorizontalAlignment="Left" MinWidth="100" Margin="0,0,0,8"
                            ItemsSource="{Binding PulseTimingCoefficientChoices}"
                            SelectedValue="{Binding RunPulseTimingCoefficient, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ToolTip>
                      <TextBlock MaxWidth="360" TextWrapping="Wrap">Сокращает паузы между фазами пульса в N раз. Фактическое ускорение ограничено временем вычислений агента (~15 пульс/сек), поэтому значения выше 20 не дают прироста.</TextBlock>
                    </ComboBox.ToolTip>
                  </ComboBox>
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Очистить данные" VerticalAlignment="Center" Margin="0,0,12,8"
                             FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1"/>
                  <CheckBox Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,8"
                            IsChecked="{Binding PreRunClearAgentData, UpdateSourceTrigger=PropertyChanged}">
                    <CheckBox.ToolTip>
                      <ToolTip>
                        <TextBlock MaxWidth="360" TextWrapping="Wrap"
                                   Text="Очищать данные для текущей стадии (как при смене стадии в свойствах агента)."/>
                      </ToolTip>
                    </CheckBox.ToolTip>
                  </CheckBox>
                  <TextBlock Grid.Row="3" Grid.Column="0" Text="Начальное состояние Норма" VerticalAlignment="Center" Margin="0,0,12,8"
                             FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1"/>
                  <CheckBox Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,8"
                            IsChecked="{Binding PreRunNormalHomeostasisState, UpdateSourceTrigger=PropertyChanged}">
                    <CheckBox.ToolTip>
                      <ToolTip>
                        <TextBlock MaxWidth="360" TextWrapping="Wrap"
                                   Text="Перед запуском: дефицит (Speed &lt; 0) → 100, избыток (Speed &gt; 0) → 0 с усечением по критическим границам; затем пауза на время удержания состояний + 1 пульс для стабилизации перед первым шагом."/>
                      </ToolTip>
                    </CheckBox.ToolTip>
                  </CheckBox>
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="Режим наблюдения" VerticalAlignment="Center" Margin="0,0,12,8"
                             FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1"/>
                  <CheckBox Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,8"
                            IsChecked="{Binding ScenarioObservationMode, UpdateSourceTrigger=PropertyChanged}">
                    <CheckBox.ToolTip>
                      <ToolTip>
                        <TextBlock MaxWidth="360" TextWrapping="Wrap"
                                   Text="Режим наблюдения при прогоне: не применять воздействия к гомеостазу на шагах сценария (как флажок на пульте)."/>
                      </ToolTip>
                    </CheckBox.ToolTip>
                  </CheckBox>
                  <TextBlock Grid.Row="5" Grid.Column="0" Text="Авторитарная запись" VerticalAlignment="Center" Margin="0,0,12,0"
                             FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1"/>
                  <CheckBox Grid.Row="5" Grid.Column="1" VerticalAlignment="Center"
                            IsChecked="{Binding ScenarioAuthoritativeRecording, UpdateSourceTrigger=PropertyChanged}">
                    <CheckBox.ToolTip>
                      <ToolTip>
                        <TextBlock MaxWidth="360" TextWrapping="Wrap"
                                   Text="Авторитарная запись при прогоне: усл. рефлексы с первого раза; вербал сразу в деревья (как на пульте)."/>
                      </ToolTip>
                    </CheckBox.ToolTip>
                  </CheckBox>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
      <TabItem Header="Шаги и ожидаемый результат">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
        <TextBlock Text="Приращение пульса на шаге:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="#FF37474F"/>
        <ComboBox Width="340"
                  Padding="4,3"
                  FontSize="12"
                  VerticalAlignment="Center"
                  ItemsSource="{Binding PulseStepIncrementChoices}"
                  SelectedValue="{Binding PulseStepIncrement, UpdateSourceTrigger=PropertyChanged}"
                  DisplayMemberPath="Label"
                  SelectedValuePath="Code">
          <ComboBox.ToolTip>
            <ToolTip>
              <TextBlock MaxWidth="400" TextWrapping="Wrap"
                         Text="Влияет только на подстановку «№ пульса» при добавлении новой строки и при повторе блока: приращение = зазор из настроек проекта (+0; время удержания действий; время удержания состояний) плюс, кроме режима «Время удержания действий», ещё 1 пульс; при нулевом зазоре минимум +1. Уже введённые номера не меняются."/>
            </ToolTip>
          </ComboBox.ToolTip>
        </ComboBox>
      </StackPanel>
      <Border BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" MinHeight="200">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="#FFE8EAF6" BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1" Padding="10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="ШАГИ СЦЕНАРИЯ" FontWeight="Bold" FontSize="15" Foreground="#FF3F51B5" VerticalAlignment="Center"/>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Повторить, раз:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                <TextBox Width="52" Padding="4,3" FontSize="12" VerticalContentAlignment="Center"
                         Text="{Binding RepeatBlockCountText, UpdateSourceTrigger=PropertyChanged}">
                  <TextBox.ToolTip>
                    <ToolTip>
                      <TextBlock MaxWidth="380" TextWrapping="Wrap"
                                 Text="Целое число &gt; 0. Выделите подряд идущие строки блока и нажмите «Повторить» — копии вставятся сразу после блока; шаг пульса между концом блока и началом копии — по выбранному выше режиму приращения."/>
                    </ToolTip>
                  </TextBox.ToolTip>
                </TextBox>
                <Button Content="Повторить" Padding="10,5" FontSize="12" Margin="10,0,10,0" Cursor="Hand"
                        Click="RepeatBlockButton_Click"/>
                <Button Content="Добавить запись" Padding="10,5" FontSize="12" Command="{Binding AddLineCommand}" Cursor="Hand"/>
              </StackPanel>
            </Grid>
          </Border>
          <DataGrid x:Name="LinesGrid"
                    Grid.Row="1"
                    ItemsSource="{Binding Lines}"
                    SelectedItem="{Binding SelectedLine}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    SelectionMode="Extended"
                    HeadersVisibility="Column"
                    Style="{StaticResource LinkDataGridStyle}"
                    RowStyle="{StaticResource HighlightedRowStyle}"
                    MouseDoubleClick="LinesGrid_OnMouseDoubleClick"
                    CellEditEnding="LinesGrid_OnCellEditEnding"
                    PreviewKeyDown="LinesGrid_OnPreviewKeyDown">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Шаг"
                                  Binding="{Binding StepIndex, UpdateSourceTrigger=PropertyChanged}"
                                  Width="56"
                                  IsReadOnly="False">
                <DataGridTextColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="ToolTip" Value="Порядковый номер шага (1, 2, 3 …). После правки пересчитывается № пульса."/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTextColumn.HeaderStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="№ пульса"
                                  Binding="{Binding PulseWithinScenario, UpdateSourceTrigger=PropertyChanged}"
                                  Width="80"
                                  IsReadOnly="False">
                <DataGridTextColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="ToolTip" Value="Номер пульса внутри прогона (можно править вручную). Для новой строки по-прежнему подставляется расчётное значение. При сохранении каждый следующий шаг должен иметь пульс строго больше, чем у предыдущего."/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTextColumn.HeaderStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="Воздействия"
                                  Binding="{Binding ActionNamesDisplay}"
                                  Width="2*"
                                  IsReadOnly="True">
                <DataGridTextColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="ToolTip" Value="Двойной щелчок — выбор воздействий из справочника"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTextColumn.HeaderStyle>
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                    <Setter Property="ToolTip" Value="{Binding ActionNamesDisplay}"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="Фраза" Binding="{Binding Phrase, UpdateSourceTrigger=PropertyChanged}" Width="2*">
                <DataGridTextColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTextColumn.HeaderStyle>
              </DataGridTextColumn>
              <DataGridTemplateColumn Header="Тон" Width="130">
                <DataGridTemplateColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTemplateColumn.HeaderStyle>
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ComboBox ItemsSource="{Binding DataContext.ToneChoiceOptions, ElementName=EditorRoot}"
                              SelectedValue="{Binding ToneId, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Id"
                              Padding="2,1"
                              FontSize="12"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTemplateColumn Header="Настроение" Width="150">
                <DataGridTemplateColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTemplateColumn.HeaderStyle>
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ComboBox ItemsSource="{Binding DataContext.MoodChoiceOptions, ElementName=EditorRoot}"
                              SelectedValue="{Binding MoodId, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Id"
                              Padding="2,1"
                              FontSize="12"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridCheckBoxColumn Header="Сброс ожидания" Binding="{Binding ResetWaitingPeriod}" Width="120">
                <DataGridCheckBoxColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridCheckBoxColumn.HeaderStyle>
              </DataGridCheckBoxColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

    <StackPanel Margin="0,10,0,6">
      <TextBlock Text="Ожидаемые логи"
                 FontWeight="Bold" FontSize="14" Foreground="#FF37474F"/>
      <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FF616161" Margin="0,2,0,0"
                 Text="«Пусто» — в логе ожидается прочерк. «Неизвестно» — столбец не проверяется. Иное — точное совпадение."/>
    </StackPanel>

    <Border BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" MinHeight="220">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FFFFF8E1" BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1" Padding="10">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="ОЖИДАЕМЫЙ РЕЗУЛЬТАТ (ПО ПУЛЬСУ)" FontWeight="Bold" FontSize="14" Foreground="#FF795548" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="Массово:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
              <ComboBox Width="200" Margin="0,0,8,0"
                        ItemsSource="{Binding MassFillOptions}"
                        SelectedValue="{Binding MassFillMode, UpdateSourceTrigger=PropertyChanged}"
                        DisplayMemberPath="Label" SelectedValuePath="Code"/>
              <Button Content="ОК" Padding="12,4" Margin="0,0,8,0" Command="{Binding MassFillExpectationsCommand}"/>
            </StackPanel>
          </Grid>
        </Border>
        <DataGrid x:Name="ExpectGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding ExpectationRows}"
                  SelectedItem="{Binding SelectedExpectationRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  Style="{StaticResource LinkDataGridStyle}"
                  RowStyle="{StaticResource HighlightedRowStyle}"
                  CellEditEnding="ExpectGrid_OnCellEditEnding">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Шаг" Binding="{Binding StepIndex}" Width="48" IsReadOnly="True"/>
            <DataGridTextColumn Header="№ пульса" Binding="{Binding PulseWithinScenario}" Width="68" IsReadOnly="True"/>
            <DataGridTemplateColumn Header="Состояние" Width="120">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <ComboBox ItemsSource="{Binding DataContext.StateChoiceOptions, ElementName=EditorRoot}"
                            SelectedValue="{Binding StateText, UpdateSourceTrigger=PropertyChanged}"
                            DisplayMemberPath="Label" SelectedValuePath="Code"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="Стиль" Width="120">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <ComboBox ItemsSource="{Binding DataContext.StyleChoiceOptions, ElementName=EditorRoot}"
                            SelectedValue="{Binding StyleText, UpdateSourceTrigger=PropertyChanged}"
                            DisplayMemberPath="Label" SelectedValuePath="Code"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Тема" Binding="{Binding ThemeText, UpdateSourceTrigger=PropertyChanged}" Width="56"/>
            <DataGridTextColumn Header="Триггер" Binding="{Binding TriggerText, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
            <DataGridTemplateColumn Header="ОР/УМ" Width="100">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <ComboBox ItemsSource="{Binding DataContext.OrUmChoiceOptions, ElementName=EditorRoot}"
                            SelectedValue="{Binding OrUmText, UpdateSourceTrigger=PropertyChanged}"
                            DisplayMemberPath="Label" SelectedValuePath="Code"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Б/у рефлекс" Binding="{Binding GeneticReflexText, UpdateSourceTrigger=PropertyChanged}" Width="88"/>
            <DataGridTextColumn Header="Усл. рефлекс" Binding="{Binding ConditionReflexText, UpdateSourceTrigger=PropertyChanged}" Width="88"/>
            <DataGridTextColumn Header="Автоматизм" Binding="{Binding AutomatizmText, UpdateSourceTrigger=PropertyChanged}" Width="88"/>
            <DataGridTextColumn Header="Цепочка РФ" Binding="{Binding ReflexChainText, UpdateSourceTrigger=PropertyChanged}" Width="88"/>
            <DataGridTextColumn Header="Цепочка АВ" Binding="{Binding AutomatizmChainText, UpdateSourceTrigger=PropertyChanged}" Width="88"/>
            <DataGridTextColumn Header="Цикл М" Binding="{Binding MainCycleText, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>

      </StackPanel>
    </ScrollViewer>
      </TabItem>
    </TabControl>

    <Border Grid.Row="2"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10,8"
            Margin="0,6,0,4"
            Background="#FFF9FBE7">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Сохранять файл отчёта в:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
        <TextBox Grid.Column="1" Text="{Binding ReportOutputFolder, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,3" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <Button Grid.Column="2" Content="Обзор…" Padding="10,4" Margin="0,0,0,0"
                Command="{Binding BrowseReportFolderCommand}" VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <Border Grid.Row="3"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10,8"
            Margin="0,0,0,0"
            Background="#FFF5F5F5">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Сохранить" Padding="12,6" Margin="0,0,8,0" IsDefault="True" Command="{Binding SaveCommand}"
                Background="#FF4CAF50" BorderBrush="#FF388E3C" Foreground="White" FontWeight="SemiBold"/>
        <Button Content="Закрыть" Padding="12,6" Click="CloseButton_Click"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
