<UserControl x:Class="AIStudio.Pages.Research.ScenarioEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="EditorRoot"
        MinHeight="400">
  <UserControl.Resources>
    <Style x:Key="LinkDataGridStyle" TargetType="DataGrid">
      <Setter Property="Background" Value="White"/>
      <Setter Property="RowBackground" Value="#FFF9F9F9"/>
      <Setter Property="AlternatingRowBackground" Value="#FFF0F0F0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="GridLinesVisibility" Value="None"/>
      <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
      <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
      <Setter Property="SelectionUnit" Value="FullRow"/>
      <Setter Property="CanUserAddRows" Value="False"/>
      <Setter Property="CanUserDeleteRows" Value="False"/>
      <Setter Property="CanUserSortColumns" Value="False"/>
    </Style>
    <Style x:Key="HighlightedRowStyle" TargetType="DataGridRow">
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#FFE3F2FD"/>
          <Setter Property="BorderBrush" Value="#FF2196F3"/>
          <Setter Property="BorderThickness" Value="1"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="InfoTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
  </UserControl.Resources>
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" Content="← Назад к реестру" Padding="10,6" Margin="0,0,10,0"
              VerticalAlignment="Center" Click="BackButton_Click" Cursor="Hand"/>
      <Border Grid.Column="1"
              Background="#FF2196F3"
              CornerRadius="3"
              Padding="6,8" VerticalAlignment="Center">
        <TextBlock Text="РЕДАКТОР СЦЕНАРИЯ ОПЕРАТОРА"
                   FontSize="14"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="White"/>
      </Border>
    </Grid>

    <TabControl Grid.Row="1" Margin="0,0,0,4" Padding="0,4,0,0"
                VerticalContentAlignment="Stretch">
      <TabItem Header="Сведения">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="4">
          <Border BorderBrush="#FFBBDEFB"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="10,8"
                  Background="#FFE3F2FD">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Название" VerticalAlignment="Center" Margin="0,0,10,6"
                         FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1"/>
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" Padding="4,3" FontSize="12"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Описание" VerticalAlignment="Top" Margin="0,0,10,6"
                         FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1"/>
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" MinHeight="80" MaxHeight="220"
                       TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,6" Padding="4,3" FontSize="12"/>
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата" VerticalAlignment="Center" Margin="0,0,10,0"
                         FontSize="12" FontWeight="SemiBold" Foreground="#FF0D47A1"/>
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DateText, UpdateSourceTrigger=PropertyChanged}" Width="160" HorizontalAlignment="Left" Padding="4,3" FontSize="12"/>
            </Grid>
          </Border>
        </ScrollViewer>
      </TabItem>
      <TabItem Header="Шаги, логи и сравнение">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
      <Border BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" MinHeight="200">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="#FFE8EAF6" BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1" Padding="10">
            <TextBlock Text="ШАГИ СЦЕНАРИЯ" FontWeight="Bold" FontSize="15" Foreground="#FF3F51B5"/>
          </Border>
          <DataGrid x:Name="LinesGrid"
                    Grid.Row="1"
                    ItemsSource="{Binding Lines}"
                    SelectedItem="{Binding SelectedLine}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="True"
                    CanUserDeleteRows="False"
                    SelectionMode="Extended"
                    HeadersVisibility="Column"
                    Style="{StaticResource LinkDataGridStyle}"
                    RowStyle="{StaticResource HighlightedRowStyle}"
                    MouseDoubleClick="LinesGrid_OnMouseDoubleClick"
                    CellEditEnding="LinesGrid_OnCellEditEnding"
                    PreviewKeyDown="LinesGrid_OnPreviewKeyDown">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Шаг"
                                  Binding="{Binding StepIndex, UpdateSourceTrigger=PropertyChanged}"
                                  Width="56"
                                  IsReadOnly="False">
                <DataGridTextColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="ToolTip" Value="Порядковый номер шага (1, 2, 3 …). После правки пересчитывается № пульса."/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTextColumn.HeaderStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="№ пульса"
                                  Binding="{Binding PulseWithinScenario}"
                                  Width="80"
                                  IsReadOnly="True">
                <DataGridTextColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="ToolTip" Value="Расчётный номер пульса внутри прогона."/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTextColumn.HeaderStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="Воздействия"
                                  Binding="{Binding ActionNamesDisplay}"
                                  Width="2*"
                                  IsReadOnly="True">
                <DataGridTextColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="ToolTip" Value="Двойной щелчок — выбор воздействий из справочника"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTextColumn.HeaderStyle>
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                    <Setter Property="ToolTip" Value="{Binding ActionNamesDisplay}"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="Фраза" Binding="{Binding Phrase, UpdateSourceTrigger=PropertyChanged}" Width="2*">
                <DataGridTextColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTextColumn.HeaderStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="Тон" Binding="{Binding ToneId}" Width="56">
                <DataGridTextColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTextColumn.HeaderStyle>
              </DataGridTextColumn>
              <DataGridTextColumn Header="Настроение" Binding="{Binding MoodId}" Width="88">
                <DataGridTextColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridTextColumn.HeaderStyle>
              </DataGridTextColumn>
              <DataGridCheckBoxColumn Header="Сброс ожидания" Binding="{Binding ResetWaitingPeriod}" Width="120">
                <DataGridCheckBoxColumn.HeaderStyle>
                  <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </DataGridCheckBoxColumn.HeaderStyle>
              </DataGridCheckBoxColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

    <StackPanel Margin="0,10,0,6">
      <TextBlock Text="Ожидаемые логи (как в «Системных логах»)"
                 FontWeight="Bold" FontSize="14" Foreground="#FF37474F"/>
      <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FF616161" Margin="0,2,0,0"
                 Text="«-» — в логе ожидается прочерк. Пустая ячейка — столбец не проверяется. Иное значение — точное совпадение с логом."/>
    </StackPanel>

    <Border BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" MinHeight="180">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FFFFF8E1" BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1" Padding="10">
          <TextBlock Text="ОЖИДАЕМЫЙ РЕЗУЛЬТАТ (ПО ПУЛЬСУ)" FontWeight="Bold" FontSize="14" Foreground="#FF795548"/>
        </Border>
        <DataGrid x:Name="ExpectGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding ExpectationRows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  Style="{StaticResource LinkDataGridStyle}"
                  RowStyle="{StaticResource HighlightedRowStyle}"
                  CellEditEnding="ExpectGrid_OnCellEditEnding">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Шаг" Binding="{Binding StepIndex}" Width="48" IsReadOnly="True"/>
            <DataGridTextColumn Header="№ пульса" Binding="{Binding PulseWithinScenario}" Width="72" IsReadOnly="True"/>
            <DataGridTextColumn Header="Состояние" Binding="{Binding StateText, UpdateSourceTrigger=PropertyChanged}" Width="88"/>
            <DataGridTextColumn Header="Стиль" Binding="{Binding StyleText, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
            <DataGridTextColumn Header="Тема" Binding="{Binding ThemeText, UpdateSourceTrigger=PropertyChanged}" Width="56"/>
            <DataGridTextColumn Header="Триггер" Binding="{Binding TriggerText, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
            <DataGridTextColumn Header="ОР/УМ" Binding="{Binding OrUmText, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
            <DataGridTextColumn Header="Б/у рефлекс" Binding="{Binding GeneticReflexText, UpdateSourceTrigger=PropertyChanged}" Width="88"/>
            <DataGridTextColumn Header="Усл. рефлекс" Binding="{Binding ConditionReflexText, UpdateSourceTrigger=PropertyChanged}" Width="88"/>
            <DataGridTextColumn Header="Автоматизм" Binding="{Binding AutomatizmText, UpdateSourceTrigger=PropertyChanged}" Width="88"/>
            <DataGridTextColumn Header="Цепочка РФ" Binding="{Binding ReflexChainText, UpdateSourceTrigger=PropertyChanged}" Width="88"/>
            <DataGridTextColumn Header="Цепочка АВ" Binding="{Binding AutomatizmChainText, UpdateSourceTrigger=PropertyChanged}" Width="88"/>
            <DataGridTextColumn Header="Цикл М" Binding="{Binding MainCycleText, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>

    <Grid Margin="0,10,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Сравнение с текущими логами в памяти"
                 VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="#FF37474F"/>
      <Button Grid.Column="1" Content="Сравнить с логами" Padding="12,6"
              Command="{Binding CompareWithLogsCommand}"/>
    </Grid>

    <Border BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" MinHeight="120">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FFE8F5E9" BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1" Padding="10">
          <TextBlock Text="РЕЗУЛЬТАТ СРАВНЕНИЯ" FontWeight="Bold" FontSize="14" Foreground="#FF2E7D32"/>
        </Border>
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding CompareResults}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  Style="{StaticResource LinkDataGridStyle}"
                  RowStyle="{StaticResource HighlightedRowStyle}">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Шаг" Binding="{Binding StepIndex}" Width="56"/>
            <DataGridTextColumn Header="Пульс" Binding="{Binding PulseWithinScenario}" Width="72"/>
            <DataGridTextColumn Header="Итог" Binding="{Binding OkLabel}" Width="56"/>
            <DataGridTextColumn Header="Пояснение" Binding="{Binding Details}" Width="*"/>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>

      </StackPanel>
    </ScrollViewer>
      </TabItem>
    </TabControl>

    <Border Grid.Row="2"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10,8"
            Margin="0,6,0,0"
            Background="#FFF5F5F5">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Сохранить" Padding="12,6" Margin="0,0,8,0" IsDefault="True" Command="{Binding SaveCommand}"
                Background="#FF4CAF50" BorderBrush="#FF388E3C" Foreground="White" FontWeight="SemiBold"/>
        <Button Content="Закрыть" Padding="12,6" Click="CloseButton_Click"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
