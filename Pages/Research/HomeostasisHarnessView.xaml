<UserControl x:Class="AIStudio.Pages.Research.HomeostasisHarnessView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

             mc:Ignorable="d"

             d:DesignHeight="640" d:DesignWidth="820">

  <Grid Margin="12">

    <Grid.RowDefinitions>

      <RowDefinition Height="Auto"/>

      <RowDefinition Height="Auto"/>

      <RowDefinition Height="Auto"/>

      <RowDefinition Height="Auto"/>

      <RowDefinition Height="Auto"/>

      <RowDefinition Height="*"/>

      <RowDefinition Height="Auto"/>

      <RowDefinition Height="Auto"/>

    </Grid.RowDefinitions>



    <TextBlock Grid.Row="0" Text="Исследовательские прогоны гомеостаза" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>



    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">

      <TextBlock Text="Метод:" VerticalAlignment="Center" Margin="0,0,8,0"/>

      <ComboBox Width="480"

                ItemsSource="{Binding Methods}"

                DisplayMemberPath="Title"

                SelectedItem="{Binding SelectedMethod, Mode=TwoWay}"/>

      <Button Content="Пример строк" Margin="12,0,0,0" Padding="12,4" Command="{Binding LoadSampleCommand}"

              ToolTip="Встроенный пример (не из файла)"/>

    </StackPanel>



    <GroupBox Grid.Row="2" Header="Сценарий" Margin="0,0,0,8" Padding="8">

      <Grid>

        <Grid.RowDefinitions>

          <RowDefinition Height="Auto"/>

          <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">

          <TextBlock Text="Файлы:" VerticalAlignment="Center" Margin="0,0,8,0"/>

          <ComboBox Width="220" ItemsSource="{Binding SavedScenarioNames}"

                    SelectedItem="{Binding SelectedSavedScenario, Mode=TwoWay}"

                    ToolTip="Выберите имя — текст строк подгрузится из файла"/>

          <TextBlock Text="Имя для сохранения:" VerticalAlignment="Center" Margin="16,0,8,0"/>

          <TextBox Width="200" VerticalAlignment="Center" Text="{Binding ScenarioSaveName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="24"/>

          <Button Content="Сохранить сценарий" Margin="12,0,0,0" Padding="10,4" Command="{Binding SaveScenarioCommand}"/>

          <Button Content="Обновить список" Margin="8,0,0,0" Padding="10,4" Command="{Binding RefreshScenarioListCommand}"/>

          <Button Content="Папка сценариев" Margin="8,0,0,0" Padding="10,4" Command="{Binding OpenScenariosFolderCommand}"/>

        </StackPanel>

        <TextBlock Grid.Row="1" Text="Путь: …\ResearchHarness\Scenarios\&lt;harness_id&gt;\&lt;имя&gt;.txt (корень задаётся в настройках)" FontSize="11" Foreground="#666" Margin="0,6,0,0" TextWrapping="Wrap"/>

      </Grid>

    </GroupBox>



    <GroupBox Grid.Row="3" Header="Карточка метода" Margin="0,0,0,8" Padding="8">

      <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">

        <TextBlock Text="{Binding MethodCardText}" TextWrapping="Wrap" FontSize="13"/>

      </ScrollViewer>

    </GroupBox>



    <StackPanel Grid.Row="4" Margin="0,0,0,6">

      <TextBlock Text="Формат одной строки (разделитель «|»):" FontWeight="SemiBold" Margin="0,0,0,4"/>

      <TextBlock Text="{Binding PipeFormatHint}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Foreground="#37474F"/>

    </StackPanel>



    <GroupBox Grid.Row="5" Header="Строки прогона (каждая строка — шаг; # в начале — комментарий)" Margin="0,0,0,8">

      <Grid>

        <Grid.RowDefinitions>

          <RowDefinition Height="*"/>

          <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <TextBox Grid.Row="0"

                 Text="{Binding PipeLinesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"

                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"

                 FontFamily="Consolas" FontSize="12" MinHeight="120"/>

        <Button Grid.Row="1" Content="Автогенерация строк"

                Margin="0,8,0,0" Padding="10,5" HorizontalAlignment="Left"

                Command="{Binding AutoGenerateScenarioCommand}"

                ToolTip="Эталонные строки для текущего метода (Out1 = калькулятор). Если поле не пустое — спросит: заменить целиком или добавить в конец."/>

      </Grid>

    </GroupBox>



    <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,8">

      <Button Content="Выполнить прогон" Padding="14,6" Command="{Binding RunCommand}" IsDefault="True"/>

      <Button Content="Каталог прогонов" Margin="10,0,0,0" Padding="12,6" Command="{Binding OpenRunsRootCommand}"

              ToolTip="Корневой каталог из настроек (ResearchHarness)"/>

      <Button Content="Последний отчёт" Margin="10,0,0,0" Padding="12,6" Command="{Binding OpenLastReportCommand}"/>

    </StackPanel>



    <ScrollViewer Grid.Row="7" VerticalScrollBarVisibility="Auto" MaxHeight="96" HorizontalScrollBarVisibility="Disabled">

      <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#37474F"/>

    </ScrollViewer>

  </Grid>

</UserControl>

