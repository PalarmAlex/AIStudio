<UserControl x:Class="AIStudio.Pages.Research.ScenarioGroupEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="GroupEditorRoot"
             MinHeight="400">
  <UserControl.Resources>
    <Style x:Key="GridStyle" TargetType="DataGrid">
      <Setter Property="Background" Value="White"/>
      <Setter Property="RowBackground" Value="#FFF9F9F9"/>
      <Setter Property="AlternatingRowBackground" Value="#FFF0F0F0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="GridLinesVisibility" Value="None"/>
      <Setter Property="CanUserAddRows" Value="False"/>
      <Setter Property="CanUserDeleteRows" Value="False"/>
    </Style>
    <Style x:Key="StageItemContainerStyle" TargetType="ComboBoxItem">
      <Setter Property="ToolTip" Value="{Binding Description}"/>
    </Style>
  </UserControl.Resources>
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" Content="← Назад к реестру групп" Padding="10,6" Margin="0,0,10,0"
              VerticalAlignment="Center" Click="BackButton_Click" Cursor="Hand"/>
      <Border Grid.Column="1"
              Background="#FF2196F3"
              CornerRadius="3"
              Padding="6,8" VerticalAlignment="Center">
        <TextBlock Text="РЕДАКТОР ГРУППЫ СЦЕНАРИЕВ"
                   FontSize="14"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="White"/>
      </Border>
    </Grid>

    <Border Grid.Row="1" Margin="0,0,0,8" Padding="10" BorderBrush="#FFBBDEFB" BorderThickness="1" CornerRadius="4" Background="#FFE3F2FD">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
          <TextBlock Text="Коэфф. пульсации (для всех сценариев группы)" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <ComboBox Padding="4,3" HorizontalAlignment="Left" MinWidth="120"
                    ItemsSource="{Binding PulseTimingCoefficientChoices}"
                    SelectedItem="{Binding RunPulseTimingCoefficient, UpdateSourceTrigger=PropertyChanged}">
            <ComboBox.ToolTip>
              <TextBlock MaxWidth="360" TextWrapping="Wrap">Сокращает паузы между фазами пульса в N раз. Фактическое ускорение ограничено временем вычислений агента (~15 пульс/сек), поэтому значения выше 20 не дают прироста.</TextBlock>
            </ComboBox.ToolTip>
          </ComboBox>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
          <TextBlock Text="Тип отчёта после группового прогона" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <ComboBox Padding="4,3" HorizontalAlignment="Left" MinWidth="200"
                    ItemsSource="{Binding ReportFormatChoices}"
                    SelectedValue="{Binding ReportFormat, UpdateSourceTrigger=PropertyChanged}"
                    SelectedValuePath="Format"
                    DisplayMemberPath="Display"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,8">
          <TextBlock Text="Название" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Padding="4,3"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,0">
          <TextBlock Text="Описание" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Padding="4,3" MinHeight="72"
                   TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                   ToolTipService.IsEnabled="False"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
        <Button Content="Добавить строку" Padding="8,4" Margin="0,0,8,0" Command="{Binding AddMemberCommand}" Cursor="Hand"/>
      </StackPanel>
      <DataGrid Grid.Row="1" ItemsSource="{Binding Members}" SelectedItem="{Binding SelectedMember, Mode=TwoWay}"
                Style="{StaticResource GridStyle}" AutoGenerateColumns="False" SelectionUnit="FullRow"
                PreviewKeyDown="MembersDataGrid_OnPreviewKeyDown">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Сорт." Binding="{Binding SortOrderInGroup, UpdateSourceTrigger=PropertyChanged}" Width="56"/>
          <DataGridTemplateColumn Header="Сценарий" Width="*">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border Background="Transparent" Padding="2,4" Cursor="Hand"
                        MouseDown="ScenarioCell_OnMouseDown">
                  <TextBlock Text="{Binding ScenarioCellDisplay}"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center"
                             ToolTip="{Binding ScenarioSelectionToolTip}"/>
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="Стадия" Width="220">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <ComboBox Padding="2"
                          ToolTip="{Binding StageSelectionToolTip}"
                          ItemsSource="{Binding DataContext.PreRunStageChoices, ElementName=GroupEditorRoot}"
                          SelectedValue="{Binding PreRunTargetStage, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="StageNumber"
                          DisplayMemberPath="Description"
                          ItemContainerStyle="{StaticResource StageItemContainerStyle}"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridCheckBoxColumn Header="Очистить данные" Binding="{Binding PreRunClearAgentData, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
          <DataGridCheckBoxColumn Header="Норма" Binding="{Binding PreRunNormalHomeostasisState, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
          <DataGridCheckBoxColumn Header="Наблюдение" Binding="{Binding ScenarioObservationMode, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
          <DataGridCheckBoxColumn Header="Авт.запись" Binding="{Binding ScenarioAuthoritativeRecording, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
        </DataGrid.Columns>
      </DataGrid>
    </Grid>

    <Border Grid.Row="3"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10,8"
            Margin="0,10,0,0"
            Background="#FFF5F5F5">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Сохранить" Padding="12,6" Margin="0,0,8,0" IsDefault="True" Command="{Binding SaveCommand}"
                Background="#FF4CAF50" BorderBrush="#FF388E3C" Foreground="White" FontWeight="SemiBold"/>
        <Button Content="Закрыть" Padding="12,6" Click="CloseButton_Click"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
