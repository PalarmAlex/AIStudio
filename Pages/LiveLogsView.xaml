<UserControl x:Class="AIStudio.Pages.LiveLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:AIStudio.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1050">

  <UserControl.Resources>

    <converters:StyleTooltipMultiConverter x:Key="StyleTooltipConverter"/>
    <converters:TriggerTooltipMultiConverter x:Key="TriggerTooltipConverter"/>
    <converters:ActionsForGeneticReflexConverter x:Key="ActionsForGeneticReflexConverter"/>
    <converters:ActionsForConditionReflexConverter x:Key="ActionsForConditionReflexConverter"/>
    <converters:AutomatizmTooltipMultiConverter x:Key="AutomatizmTooltipConverter"/>
    <converters:OrUmTooltipMultiConverter x:Key="OrUmTooltipConverter"/>

    <!-- Стиль для текста матрицы -->
    <Style x:Key="MatrixTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#FF00FF00"/>
      <Setter Property="FontFamily" Value="Consolas, Courier New"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Стиль для заголовков колонок DataGrid -->
    <Style x:Key="MatrixHeaderStyle" TargetType="DataGridColumnHeader">
      <Setter Property="Foreground" Value="#FFFFFF00"/>
      <Setter Property="FontFamily" Value="Consolas, Courier New"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Background" Value="#101010"/>
      <Setter Property="BorderBrush" Value="#00FF00"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
      <Setter Property="Padding" Value="5,3"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <!-- Стиль для ячеек DataGrid -->
    <Style x:Key="MatrixCellStyle" TargetType="DataGridCell">
      <Setter Property="Foreground" Value="#FF00FF00"/>
      <Setter Property="FontFamily" Value="Consolas, Courier New"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="#202020"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
      <Setter Property="Padding" Value="5,3"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="DataGridCell">
            <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
              <ContentPresenter VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#2000FF00"/>
          <Setter Property="Foreground" Value="#FFFFFF"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Стиль для строк таблицы -->
    <Style x:Key="MatrixRowStyle" TargetType="DataGridRow">
      <Setter Property="Background" Value="Transparent"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#1000FF00"/>
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#3000FF00"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Стиль для кнопок матрицы -->
    <Style x:Key="MatrixButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#002000"/>
      <Setter Property="Foreground" Value="#00FF00"/>
      <Setter Property="BorderBrush" Value="#00FF00"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#004000"/>
          <Setter Property="Foreground" Value="#80FF80"/>
        </Trigger>
        <Trigger Property="IsPressed" Value="True">
          <Setter Property="Background" Value="#006000"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Стиль для самого DataGrid -->
    <Style x:Key="MatrixDataGridStyle" TargetType="DataGrid">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#00FF00"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="HeadersVisibility" Value="Column"/>
      <Setter Property="RowBackground" Value="Transparent"/>
      <Setter Property="AlternatingRowBackground" Value="#080808"/>
      <Setter Property="GridLinesVisibility" Value="None"/>
      <Setter Property="HorizontalGridLinesBrush" Value="Transparent"/>
      <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
      <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
      <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
      <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
    </Style>

    <!-- Стиль для ToolTip в стиле матрицы -->
    <Style x:Key="MatrixToolTipStyle" TargetType="ToolTip">
      <Setter Property="Background" Value="#202020"/>
      <Setter Property="BorderBrush" Value="#00FF00"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#00FF00"/>
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- Стиль для ячейки Состояние -->
    <Style x:Key="StateCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Style.Triggers>
        <!-- Триггер для значения -1 (красный) -->
        <DataTrigger Binding="{Binding DisplayBaseID}" Value="-1">
          <Setter Property="Background" Value="#40FF0000"/>
          <Setter Property="ToolTip" Value="ПЛОХО"/>
        </DataTrigger>
        <!-- Триггер для значения 0 (желтый) -->
        <DataTrigger Binding="{Binding DisplayBaseID}" Value="0">
          <Setter Property="Background" Value="#40FFFF00"/>
          <Setter Property="ToolTip" Value="НОРМА"/>
        </DataTrigger>
        <!-- Триггер для значения 1 (зеленый) -->
        <DataTrigger Binding="{Binding DisplayBaseID}" Value="1">
          <Setter Property="Background" Value="#4000FF00"/>
          <Setter Property="ToolTip" Value="ХОРОШО"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- Стиль для ячейки Стиль -->
    <Style x:Key="StyleCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Setter Property="ToolTip">
        <Setter.Value>
          <MultiBinding Converter="{StaticResource StyleTooltipConverter}">
            <Binding ElementName="LogDataGrid" Path="DataContext"/>
            <Binding Path="DisplayBaseStyleID"/>
          </MultiBinding>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Стиль для ячейки Триггер -->
    <Style x:Key="TriggerCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Setter Property="ToolTip">
        <Setter.Value>
          <MultiBinding Converter="{StaticResource TriggerTooltipConverter}">
            <Binding ElementName="LogDataGrid" Path="DataContext"/>
            <Binding Path="DisplayTriggerStimulusID"/>
          </MultiBinding>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Стиль для ячейки Тема (код типа темы; расшифровка — в ToolTip из движка) -->
    <Style x:Key="ThemeCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Setter Property="ToolTip" Value="{Binding ThinkingThemeTooltip}"/>
    </Style>

    <!-- стиль для ячейки безусловного рефлекса: -->
    <Style x:Key="GeneticReflexCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Setter Property="ToolTip">
        <Setter.Value>
          <MultiBinding Converter="{StaticResource ActionsForGeneticReflexConverter}">
            <Binding ElementName="LogDataGrid" Path="DataContext"/>
            <Binding Path="DisplayGeneticReflexID"/>
          </MultiBinding>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- стиль для ячейки условного рефлекса: -->
    <Style x:Key="ConditionReflexCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Setter Property="ToolTip">
        <Setter.Value>
          <MultiBinding Converter="{StaticResource ActionsForConditionReflexConverter}">
            <Binding ElementName="LogDataGrid" Path="DataContext"/>
            <Binding Path="DisplayConditionReflexID"/>
          </MultiBinding>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Стиль для ячейки Автоматизм -->
    <Style x:Key="AutomatizmCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Setter Property="ToolTip">
        <Setter.Value>
          <MultiBinding Converter="{StaticResource AutomatizmTooltipConverter}">
            <Binding ElementName="LogDataGrid" Path="DataContext"/>
            <Binding Path="DisplayAutomatizmID"/>
            <Binding Path="AutomatizmUsefulnessAtSnapshot"/>
          </MultiBinding>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Стиль для ячейки «Опасно» (информационная среда): при опасности только красный фон, без цифры в ячейке -->
    <Style x:Key="DangerCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Style.Triggers>
        <DataTrigger Binding="{Binding InformationEnvironmentDanger}" Value="True">
          <Setter Property="Background" Value="#80FF0000"/>
          <Setter Property="ToolTip" Value="Опасная ситуация"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding InformationEnvironmentDanger}" Value="False">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="ToolTip" Value="Ситуация не опасна"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- Стиль для ячейки «Актуально»: при актуальной ситуации красный фон, без цифры в ячейке -->
    <Style x:Key="VeryActualCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Style.Triggers>
        <DataTrigger Binding="{Binding InformationEnvironmentVeryActual}" Value="True">
          <Setter Property="Background" Value="#80FF0000"/>
          <Setter Property="ToolTip" Value="Актуальная ситуация"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding InformationEnvironmentVeryActual}" Value="False">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="ToolTip" Value="Ситуация не актуальна"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- Стиль для ячейки ОР/УМ (ориентировка на стадиях ≤3; с 4-й — уровни 1–2 мышления) -->
    <Style x:Key="OrUmCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Setter Property="Foreground" Value="#00FF00"/>
      <Setter Property="ToolTip">
        <Setter.Value>
          <MultiBinding Converter="{StaticResource OrUmTooltipConverter}">
            <Binding ElementName="LogDataGrid" Path="DataContext"/>
            <Binding Path="DisplayOrUm"/>
            <Binding Path="ThinkingLevelSuccessDisplay"/>
          </MultiBinding>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding DisplayOrUm}" Value="ОР">
          <Setter Property="Background" Value="#40FF0000"/>
          <Setter Property="FontWeight" Value="Bold"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding DisplayOrUm}" Value="ОР1">
          <Setter Property="Background" Value="#40FF0000"/>
          <Setter Property="FontWeight" Value="Bold"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding DisplayOrUm}" Value="ОР2">
          <Setter Property="Background" Value="#40FFFF00"/>
          <Setter Property="FontWeight" Value="Bold"/>
        </DataTrigger>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Binding="{Binding DisplayOrUm}" Value="УМ1"/>
            <Condition Binding="{Binding ThinkingLevelSuccessDisplay}" Value="True"/>
          </MultiDataTrigger.Conditions>
          <Setter Property="Background" Value="#4000AA00"/>
        </MultiDataTrigger>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Binding="{Binding DisplayOrUm}" Value="УМ1"/>
            <Condition Binding="{Binding ThinkingLevelSuccessDisplay}" Value="False"/>
          </MultiDataTrigger.Conditions>
          <Setter Property="Background" Value="#40AA0000"/>
        </MultiDataTrigger>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Binding="{Binding DisplayOrUm}" Value="УМ2"/>
            <Condition Binding="{Binding ThinkingLevelSuccessDisplay}" Value="True"/>
          </MultiDataTrigger.Conditions>
          <Setter Property="Background" Value="#4000AA00"/>
        </MultiDataTrigger>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Binding="{Binding DisplayOrUm}" Value="УМ2"/>
            <Condition Binding="{Binding ThinkingLevelSuccessDisplay}" Value="False"/>
          </MultiDataTrigger.Conditions>
          <Setter Property="Background" Value="#40AA0000"/>
        </MultiDataTrigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Foreground" Value="#FFFFFF"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Стиль для ячейки Цепочка рефлексов -->
    <Style x:Key="ReflexChainCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Setter Property="ToolTipService.ToolTip" Value="Наведите для просмотра названия действия"/>
      <Setter Property="ToolTipService.InitialShowDelay" Value="500"/>
    </Style>

    <!-- Стиль для ячейки Цепочка автоматизмов -->
    <Style x:Key="AutomatizmChainCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Setter Property="ToolTipService.ToolTip" Value="Наведите для просмотра названия действия"/>
      <Setter Property="ToolTipService.InitialShowDelay" Value="500"/>
    </Style>

    <!-- Стиль для ячейки главного цикла мышления: номер цикла; статус — во всплывающей подсказке -->
    <Style x:Key="MainThinkingCycleCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MatrixCellStyle}">
      <Setter Property="ToolTip" Value="{Binding MainThinkingCycleTooltip}"/>
    </Style>

  </UserControl.Resources>

  <Grid Background="Black">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Заголовок -->
    <Border Grid.Row="0" Background="#101010" Padding="10" BorderBrush="#00FF00" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
        <TextBlock Text="СИСТЕМНЫЕ ЛОГИ"
                         Foreground="#00FF00"
                         FontFamily="Consolas, Courier New"
                         FontSize="16"
                         FontWeight="Bold"
                         VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- Таблица логов -->
    <Border Grid.Row="1" Margin="5" BorderBrush="#00FF00" BorderThickness="1" Background="#080808">
      <DataGrid ItemsSource="{Binding AgentDisplayLogEntries}"
                        x:Name="LogDataGrid"
                        Style="{StaticResource MatrixDataGridStyle}"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        RowStyle="{StaticResource MatrixRowStyle}"
                        CellStyle="{StaticResource MatrixCellStyle}"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="True"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        SelectionMode="Extended">

        <DataGrid.Columns>
          <DataGridTextColumn Binding="{Binding DisplayTime}" Width="80">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                                  Content="Время"
                                  ToolTip="Время создания записи лога"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayPulse}" Width="60">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                                  Content="Пульс"
                                  ToolTip="Номер пульса системы"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayBaseID}" Width="70" CellStyle="{StaticResource StateCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                                  Content="Состояние"
                                  ToolTip="ID базового состояния гомеостаза агента"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayBaseStyleID}" Width="60"
                    CellStyle="{StaticResource StyleCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                            Content="Стиль"
                            ToolTip="ID образа стилей поведения"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayThinkingThemeId}" Width="52"
                    CellStyle="{StaticResource ThemeCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                            Content="Тема"
                            ToolTip="Тема мышления"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayTriggerStimulusID}" Width="70"
                    CellStyle="{StaticResource TriggerCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                            Content="Триггер"
                            ToolTip="ID образа пускового стимула"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayOrUm}" 
                    Width="56"
                    CellStyle="{StaticResource OrUmCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                    Content="ОР/УМ"
                    ToolTip="До 4-й стадии — ориентировочный рефлекс; с 4-й — уровни мышления."/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayDangerCell}"
                    Width="52"
                    CellStyle="{StaticResource DangerCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}"
                    Content="Опасно"
                    ToolTip="Признак опасной ситуации"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayVeryActualCell}"
                    Width="70"
                    CellStyle="{StaticResource VeryActualCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}"
                    Content="Актуально"
                    ToolTip="Признак актуальной ситуации"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayGeneticReflexID}" 
                    Width="90"
                    CellStyle="{StaticResource GeneticReflexCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                            Content="Б/у рефлекс"
                            ToolTip="ID безусловного рефлекса"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayConditionReflexID}"
                              Width="90"
                              CellStyle="{StaticResource ConditionReflexCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                                  Content="Усл. рефлекс"
                                  ToolTip="ID условного рефлекса"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayAutomatizmID}" 
                    Width="80" 
                    CellStyle="{StaticResource AutomatizmCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                            Content="Автоматизм"
                            ToolTip="ID автоматизма"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayReflexChainInfo}" 
                    Width="80" 
                    CellStyle="{StaticResource ReflexChainCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                            Content="Цепочка РФ"
                            ToolTip="ID цепочки рефлекса и ID действия (ChainId:ActionId)"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayAutomatizmChainInfo}" 
                    Width="80" 
                    CellStyle="{StaticResource AutomatizmChainCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                            Content="Цепочка АВ"
                            ToolTip="ID цепочки автоматизма и ID действия (ChainId:ActionId)"/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn Binding="{Binding DisplayMainThinkingCycle}"
                    Width="64"
                    CellStyle="{StaticResource MainThinkingCycleCellStyle}">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}"
                            Content="Цикл М"
                            ToolTip="Главный цикл мышления. Фон: жёлтый — ожидание оценки, красный — нет решения, зелёный — найден автоматизм решения."/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>

          <DataGridTextColumn  Width="*">
            <DataGridTextColumn.Header>
              <DataGridColumnHeader Style="{StaticResource MatrixHeaderStyle}" 
                                  Content=""
                                  ToolTip=""/>
            </DataGridTextColumn.Header>
          </DataGridTextColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Панель управления -->
    <Border Grid.Row="2" Background="#101010" Padding="10" BorderBrush="#00FF00" BorderThickness="0,1,0,0">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="ОЧИСТИТЬ" 
                        Command="{Binding ClearLogsCommand}"
                        Style="{StaticResource MatrixButtonStyle}"
                        ToolTip="Очистить все логи"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>