<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Подсветка строки при выборе + (давление) или − (отпускание). -->
  <Style x:Key="ProbeSelectionRowBorderStyle" TargetType="Border">
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="6,4"/>
    <Setter Property="Margin" Value="2,1"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsPressure}" Value="True">
        <Setter Property="Background" Value="#FFC8E6C9"/>
        <Setter Property="BorderBrush" Value="#FF43A047"/>
      </DataTrigger>
      <DataTrigger Binding="{Binding IsRelease}" Value="True">
        <Setter Property="Background" Value="#FFEF9A9A"/>
        <Setter Property="BorderBrush" Value="#FFE53935"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

</ResourceDictionary>
