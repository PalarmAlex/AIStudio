<UserControl x:Class="AIStudio.Controls.Environment.SchemaActionPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AIStudio.Converters"
             MinWidth="500">
  <UserControl.Resources>
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
  </UserControl.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240" MinWidth="240"/>
      <ColumnDefinition Width="4"/>
      <ColumnDefinition Width="*" MinWidth="360"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" Padding="8" Background="#FFF9F9F9">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Каталог действий" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <TextBox DockPanel.Dock="Top"
                 Text="{Binding CatalogSearchText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,6"
                 Padding="4,3"
                 ToolTip="Поиск по ID и названию"/>
        <ListBox ItemsSource="{Binding CatalogItems}"
                 SelectedValuePath="Id"
                 SelectedValue="{Binding SelectedCatalogId, Mode=TwoWay}"
                 DisplayMemberPath="DisplayText"
                 BorderThickness="0"
                 Background="Transparent"
                 IsEnabled="{Binding IsEditingEnabled}"/>
      </DockPanel>
    </Border>

    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="Transparent"/>

    <Border Grid.Column="2" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="4" Padding="12" Background="White">
      <DockPanel>
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding SelectedDescription}"
                   Margin="0,8,0,0"
                   Foreground="#FF666666"
                   FontStyle="Italic"
                   TextWrapping="Wrap"/>
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ValidationError}"
                   Foreground="Red"
                   Margin="0,0,0,6"
                   TextWrapping="Wrap"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Parameters}" IsEnabled="{Binding IsEditingEnabled}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="98"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <TextBox Grid.Column="1"
                           Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                           Padding="4,3"
                           ToolTip="Для составного шаблона вставляйте маски кнопкой «Вставить…» и добавляйте разделители вручную"
                           Visibility="{Binding IsStringEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBox.Style>
                      <Style TargetType="TextBox">
                        <Setter Property="Grid.ColumnSpan" Value="2"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsTemplateField}" Value="True">
                            <Setter Property="Grid.ColumnSpan" Value="1"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsPropertyNameField}" Value="True">
                            <Setter Property="Grid.ColumnSpan" Value="1"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBox.Style>
                  </TextBox>
                  <CheckBox Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Content=""
                            IsChecked="{Binding BoolValue}"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsBool, Converter={StaticResource BoolToVisibilityConverter}}"/>
                  <ComboBox Grid.Column="1"
                            Grid.ColumnSpan="2"
                            ItemsSource="{Binding AllowedValueOptions}"
                            DisplayMemberPath="Value"
                            SelectedValuePath="Key"
                            SelectedValue="{Binding Value, Mode=TwoWay}"
                            Padding="4,3"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding IsEnum, Converter={StaticResource BoolToVisibilityConverter}}"/>
                  <Button Grid.Column="2"
                          Content="Вставить…"
                          Padding="8,3"
                          HorizontalAlignment="Stretch"
                          ToolTip="Справочник масок подстановки для шаблона значения"
                          Visibility="{Binding IsTemplateField, Converter={StaticResource BoolToVisibilityConverter}}"
                          Click="InsertPlaceholder_Click"
                          Tag="{Binding}"/>
                  <Button Grid.Column="2"
                          Content="Справочник…"
                          Padding="8,3"
                          HorizontalAlignment="Stretch"
                          ToolTip="Справочник имён свойств документа"
                          Visibility="{Binding IsPropertyNameField, Converter={StaticResource BoolToVisibilityConverter}}"
                          Click="PickPropertyName_Click"
                          Tag="{Binding}"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
