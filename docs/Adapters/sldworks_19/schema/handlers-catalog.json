{
  "schemaVersion": "3.2",
  "handlers": [
    {
      "id": "save_file_name",
      "label": "Имя файла по шаблону",
      "description": "Подстановка предлагаемого имени файла перед Save (SetTitle2); Save не вызывается",
      "argsSchema": [
        {
          "key": "template",
          "label": "Шаблон имени файла",
          "type": "string",
          "editorHint": "template_placeholder"
        }
      ]
    },
    {
      "id": "set_custom_property",
      "label": "Записать пользовательское свойство",
      "description": "Запись свойства активного документа SolidWorks",
      "argsSchema": [
        {
          "key": "config",
          "label": "Конфигурация",
          "type": "enum",
          "values": [
            { "key": "active", "label": "Активная конфигурация" },
            { "key": "document", "label": "Свойство документа" },
            { "key": "default", "label": "Конфигурация по умолчанию" }
          ]
        },
        {
          "key": "name",
          "label": "Имя свойства",
          "type": "string",
          "required": true,
          "editorHint": "property_name"
        },
        {
          "key": "template",
          "label": "Шаблон значения",
          "type": "string",
          "editorHint": "template_placeholder"
        },
        {
          "key": "overwrite",
          "label": "Политика перезаписи",
          "type": "enum",
          "values": [
            { "key": "always", "label": "Всегда" },
            { "key": "if_empty", "label": "Только если пусто" },
            { "key": "never", "label": "Временно отключить запись" }
          ]
        }
      ]
    },
    {
      "id": "run_sw_command",
      "label": "Команда SolidWorks",
      "description": "Вызов RunCommand по command_id",
      "argsSchema": [
        { "key": "command_id", "label": "Command ID", "type": "int", "required": true }
      ]
    },
    {
      "id": "rebuild",
      "label": "Перестроить модель",
      "description": "EditRebuild3 активного документа",
      "argsSchema": []
    },
    {
      "id": "log",
      "label": "Запись в лог",
      "description": "Сообщение в лог Velum (шаблоны {PLACEHOLDER} поддерживаются в message)",
      "argsSchema": [
        { "key": "message", "label": "Сообщение", "type": "string" },
        {
          "key": "level",
          "label": "Уровень",
          "type": "enum",
          "values": [
            { "key": "info", "label": "Информация" },
            { "key": "warning", "label": "Предупреждение" },
            { "key": "error", "label": "Ошибка" }
          ]
        }
      ]
    }
  ]
}
