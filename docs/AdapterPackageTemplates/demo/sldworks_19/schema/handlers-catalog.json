{
  "schemaVersion": "3.2",
  "handlers": [
    {
      "id": "save_file_name",
      "label": "Имя файла по счётчику",
      "description": "Следующее имя по обученной на Save схеме (префикс + цифровой суффикс); SetTitle2, Save не вызывается",
      "argsSchema": []
    },
    {
      "id": "assign_session_material",
      "label": "Назначить выученный материал",
      "description": "SetMaterialPropertyName2 по материалу последнего Save Part в каталоге документа; только пустая конфигурация",
      "argsSchema": []
    },
    {
      "id": "set_custom_property",
      "label": "Записать пользовательское свойство",
      "description": "Запись свойства активного документа SolidWorks",
      "argsSchema": [
        {
          "key": "config",
          "label": "Конфигурация",
          "type": "enum",
          "values": [
            { "key": "active", "label": "Активная конфигурация" },
            { "key": "document", "label": "Свойство документа" },
            { "key": "default", "label": "Конфигурация по умолчанию" }
          ]
        },
        {
          "key": "name",
          "label": "Имя свойства",
          "type": "string",
          "required": true,
          "editorHint": "property_name"
        },
        {
          "key": "property_type",
          "label": "Тип свойства",
          "type": "enum",
          "defaultValue": "text",
          "values": [
            { "key": "text", "label": "Текст" },
            { "key": "number", "label": "Число" },
            { "key": "date", "label": "Дата" },
            { "key": "boolean", "label": "Логическое (Yes/No)" }
          ]
        },
        {
          "key": "template",
          "label": "Шаблон значения",
          "type": "string",
          "editorHint": "template_placeholder"
        },
        {
          "key": "overwrite",
          "label": "Политика перезаписи",
          "type": "enum",
          "values": [
            { "key": "always", "label": "Всегда" },
            { "key": "if_empty", "label": "Только если пусто" },
            { "key": "never", "label": "Временно отключить запись" }
          ]
        }
      ]
    },
    {
      "id": "set_custom_property_if_part",
      "label": "Свойство документа (только SLDPRT)",
      "description": "Как set_custom_property, но пропускает сборки и чертежи",
      "argsSchema": [
        {
          "key": "config",
          "label": "Конфигурация",
          "type": "enum",
          "values": [
            { "key": "active", "label": "Активная конфигурация" },
            { "key": "document", "label": "Свойство документа" },
            { "key": "default", "label": "Конфигурация по умолчанию" }
          ]
        },
        {
          "key": "name",
          "label": "Имя свойства",
          "type": "string",
          "required": true,
          "editorHint": "property_name"
        },
        {
          "key": "property_type",
          "label": "Тип свойства",
          "type": "enum",
          "defaultValue": "text",
          "values": [
            { "key": "text", "label": "Текст" },
            { "key": "number", "label": "Число" },
            { "key": "date", "label": "Дата" },
            { "key": "boolean", "label": "Логическое (Yes/No)" }
          ]
        },
        {
          "key": "template",
          "label": "Шаблон значения",
          "type": "string",
          "editorHint": "template_placeholder"
        },
        {
          "key": "overwrite",
          "label": "Политика перезаписи",
          "type": "enum",
          "values": [
            { "key": "always", "label": "Всегда" },
            { "key": "if_empty", "label": "Только если пусто" },
            { "key": "never", "label": "Временно отключить запись" }
          ]
        }
      ]
    },
    {
      "id": "export_documentation_dialog",
      "label": "Диалог экспорта DXF",
      "description": "Модальная форма экспорта детали в DXF: каталог, шаблон имени, проекция",
      "argsSchema": []
    },
    {
      "id": "export_drawing_pdf_dialog",
      "label": "Диалог экспорта PDF",
      "description": "Модальная форма экспорта чертежа в PDF: выбор каталога, имя файла = имя чертежа",
      "argsSchema": []
    },
    {
      "id": "export_documentation_create_files",
      "label": "Создать PDF/DXF",
      "description": "Программное создание сопроводительных файлов для деталей с логическим Yes (вызывается из диалога)",
      "argsSchema": []
    },
    {
      "id": "run_sw_command",
      "label": "Команда SolidWorks",
      "description": "Вызов RunCommand по command_id",
      "argsSchema": [
        { "key": "command_id", "label": "Command ID", "type": "int", "required": true }
      ]
    },
    {
      "id": "rebuild",
      "label": "Перестроить модель",
      "description": "EditRebuild3 активного документа",
      "argsSchema": []
    },
    {
      "id": "log",
      "label": "Запись в лог",
      "description": "Сообщение в лог Velum (шаблоны {PLACEHOLDER} поддерживаются в message)",
      "argsSchema": [
        { "key": "message", "label": "Сообщение", "type": "string" },
        {
          "key": "level",
          "label": "Уровень",
          "type": "enum",
          "values": [
            { "key": "info", "label": "Информация" },
            { "key": "warning", "label": "Предупреждение" },
            { "key": "error", "label": "Ошибка" }
          ]
        }
      ]
    }
  ]
}
