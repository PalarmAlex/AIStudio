{

  "schemaVersion": "2.0",

  "stepTypes": [

    {

      "type": "set_property",

      "label": "Установить свойство",

      "runtimeType": "set_property",

      "parameters": [

        { "key": "config", "label": "Конфигурация", "type": "enum", "values": ["active", "document", "default"] },

        { "key": "name", "label": "Имя свойства", "type": "string", "required": true },

        { "key": "template", "label": "Шаблон значения", "type": "string" },

        { "key": "overwrite", "label": "Политика перезаписи", "type": "enum", "values": ["always", "if_empty", "never_if_filled", "never"] }

      ]

    },

    {

      "type": "run_command",

      "label": "Выполнить команду host",

      "runtimeType": "run_command",

      "parameters": [

        { "key": "command_id", "label": "Command ID", "type": "int", "required": true }

      ]

    },

    {

      "type": "refresh",

      "label": "Обновить представление",

      "runtimeType": "refresh",

      "parameters": []

    },

    {

      "type": "log",

      "label": "Запись в лог",

      "runtimeType": "log",

      "parameters": [

        { "key": "message", "label": "Сообщение", "type": "string" },

        { "key": "level", "label": "Уровень", "type": "enum", "values": ["info", "warning", "error"] }

      ]

    }

  ]

}

