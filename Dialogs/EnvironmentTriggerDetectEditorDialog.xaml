<Window x:Class="AIStudio.Dialogs.EnvironmentTriggerDetectEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AIStudio.Converters"
        Title="Правила детекции" Height="420" Width="620"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <converters:DetectKindLabelConverter x:Key="DetectKindLabelConverter"/>
  </Window.Resources>
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               TextWrapping="Wrap"
               Margin="0,0,0,10"
               Foreground="#FF444444"
               Text="Правила распознавания события среды. Тип правила — из справочника schema/trigger-detect.json пакета адаптера (универсально для любой среды). Поле «Среда» — идентификатор адаптера, в котором действует правило. Для отдельных типов (например command_before) при необходимости укажите дополнительные параметры — их смысл задаёт автор адаптера."/>

    <DataGrid x:Name="DetectGrid" Grid.Row="1" AutoGenerateColumns="False"
              CanUserAddRows="True" CanUserDeleteRows="True"
              RowBackground="#FFF9F9F9" AlternatingRowBackground="White"
              GridLinesVisibility="Horizontal" BorderBrush="#FFE0E0E0">
      <DataGrid.Columns>
        <DataGridTemplateColumn Header="Тип правила" Width="170">
          <DataGridTemplateColumn.HeaderStyle>
            <Style TargetType="DataGridColumnHeader">
              <Setter Property="ToolTip" Value="detect.kind из schema/trigger-detect.json"/>
            </Style>
          </DataGridTemplateColumn.HeaderStyle>
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Kind, Converter={StaticResource DetectKindLabelConverter}}" Padding="4,2"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
          <DataGridTemplateColumn.CellEditingTemplate>
            <DataTemplate>
              <ComboBox ItemsSource="{Binding DetectKindChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                        DisplayMemberPath="Label"
                        SelectedValuePath="Kind"
                        SelectedValue="{Binding Kind, UpdateSourceTrigger=PropertyChanged}"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellEditingTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Среда" Binding="{Binding Environment, UpdateSourceTrigger=PropertyChanged}" Width="110">
          <DataGridTextColumn.HeaderStyle>
            <Style TargetType="DataGridColumnHeader">
              <Setter Property="ToolTip" Value="Идентификатор среды — adapter id из манифеста пакета адаптера"/>
            </Style>
          </DataGridTextColumn.HeaderStyle>
        </DataGridTextColumn>
        <DataGridCheckBoxColumn Header="Вкл." Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
        <DataGridTextColumn Header="ID команд" Binding="{Binding CommandIdsText, UpdateSourceTrigger=PropertyChanged}" Width="*">
          <DataGridTextColumn.HeaderStyle>
            <Style TargetType="DataGridColumnHeader">
              <Setter Property="ToolTip" Value="Дополнительный параметр для отдельных типов правил (например command_before): значения через запятую; формат зависит от адаптера"/>
            </Style>
          </DataGridTextColumn.HeaderStyle>
        </DataGridTextColumn>
      </DataGrid.Columns>
    </DataGrid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
      <Button Content="Отмена" Width="80" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
