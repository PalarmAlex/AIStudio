<Window x:Class="AIStudio.Dialogs.EnvironmentTriggerDetectEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Правила детекции" Height="360" Width="520"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <DataGrid x:Name="DetectGrid" Grid.Row="0" AutoGenerateColumns="False"
              CanUserAddRows="True" CanUserDeleteRows="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="kind" Binding="{Binding Kind, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
        <DataGridTextColumn Header="environment" Binding="{Binding Environment, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
        <DataGridCheckBoxColumn Header="enabled" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
        <DataGridTextColumn Header="command_ids" Binding="{Binding CommandIdsText, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
      </DataGrid.Columns>
    </DataGrid>
    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
      <Button Content="Отмена" Width="80" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
