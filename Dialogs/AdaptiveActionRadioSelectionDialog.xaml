<Window x:Class="AIStudio.Dialogs.AdaptiveActionRadioSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор моторного действия" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">

  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Выберите одно моторное действие (G_AD):" Margin="0,0,0,10" FontWeight="Bold"/>
    <TextBlock Grid.Row="1" Text="Фильтр:" Margin="0,0,0,4"/>
    <TextBox x:Name="FilterTextBox" Grid.Row="2"
             Margin="0,0,0,8"
             TextChanged="FilterTextBox_TextChanged"
             ToolTip="Подстрока в ID, наименовании или описании"/>

    <ListView x:Name="ActionsList" Grid.Row="3" SelectionMode="Single"
              MouseDoubleClick="ActionsList_MouseDoubleClick">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="Выбрать" Width="60">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <RadioButton IsChecked="{Binding IsSelected}"
                             GroupName="AdaptiveActionRadioSelection"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Click="RadioButton_Click"/>
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="ID" Width="60" DisplayMemberBinding="{Binding Id}"/>
          <GridViewColumn Header="Наименование" Width="200" DisplayMemberBinding="{Binding Name}"/>
          <GridViewColumn Header="Описание" Width="280">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
        </GridView>
      </ListView.View>
    </ListView>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="OK" Width="80" Margin="0,0,10,0" Click="OkButton_Click"/>
      <Button Content="Отмена" Width="80" Click="CancelButton_Click"/>
    </StackPanel>
  </Grid>
</Window>
