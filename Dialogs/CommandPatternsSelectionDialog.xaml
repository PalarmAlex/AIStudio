<Window x:Class="AIStudio.Dialogs.CommandPatternsSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор Command patterns" Height="520" Width="760"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">

  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Паттерны Command-канала (порядок важен для genetic match):"
               Margin="0,0,0,8"
               TextWrapping="Wrap"
               FontWeight="Bold"/>
    <TextBox x:Name="FilterTextBox" Grid.Row="1"
             Margin="0,0,0,8"
             TextChanged="FilterTextBox_TextChanged"
             ToolTip="Фильтр по ID или тексту паттерна"/>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <DockPanel Grid.Column="0">
        <TextBlock DockPanel.Dock="Top" Text="Доступные" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ListBox x:Name="AvailableList"
                 DisplayMemberPath="DisplayText"
                 MouseDoubleClick="AvailableList_MouseDoubleClick"/>
      </DockPanel>

      <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
        <Button Content="&gt;&gt;" Width="40" Margin="0,4" Click="AddButton_Click"/>
        <Button Content="&lt;&lt;" Width="40" Margin="0,4" Click="RemoveButton_Click"/>
        <Button Content="▲" Width="40" Margin="0,12,0,4" Click="MoveUpButton_Click"/>
        <Button Content="▼" Width="40" Margin="0,4" Click="MoveDownButton_Click"/>
      </StackPanel>

      <DockPanel Grid.Column="2">
        <TextBlock DockPanel.Dock="Top" Text="Выбранные (порядок)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ListBox x:Name="SelectedList"
                 DisplayMemberPath="DisplayText"
                 MouseDoubleClick="SelectedList_MouseDoubleClick"/>
      </DockPanel>
    </Grid>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="OK" Width="80" Margin="0,0,10,0" Click="OkButton_Click"/>
      <Button Content="Отмена" Width="80" Click="CancelButton_Click"/>
    </StackPanel>
  </Grid>
</Window>
