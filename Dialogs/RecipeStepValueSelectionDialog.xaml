<Window x:Class="AIStudio.Dialogs.RecipeStepValueSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор значения" Height="420" Width="480"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">

  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock x:Name="PromptText" Grid.Row="0" Margin="0,0,0,10" FontWeight="Bold" TextWrapping="Wrap"/>
    <ListView x:Name="ValuesList" Grid.Row="1" SelectionMode="Single"
              MouseDoubleClick="ValuesList_MouseDoubleClick">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="Значение" Width="420" DisplayMemberBinding="{Binding}"/>
        </GridView>
      </ListView.View>
    </ListView>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="OK" Width="80" Margin="0,0,10,0" Click="OkButton_Click"/>
      <Button Content="Отмена" Width="80" Click="CancelButton_Click"/>
    </StackPanel>
  </Grid>
</Window>
