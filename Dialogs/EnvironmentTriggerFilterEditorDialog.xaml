<Window x:Class="AIStudio.Dialogs.EnvironmentTriggerFilterEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AIStudio.Converters"
        Title="Фильтр контекста триггера" Height="360" Width="480"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
  </Window.Resources>
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               TextWrapping="Wrap"
               Margin="0,0,0,10"
               Foreground="#FF444444"
               Text="Ограничения контекста, при которых срабатывает триггер. Поля и допустимые значения задаются в schema/trigger-filter.json пакета адаптера. Пустой фильтр — без ограничения по типу документа."/>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding FilterFields}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="0,0,0,4">
              <CheckBox Content="{Binding Label}"
                        IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,4"
                        Visibility="{Binding IsBoolType, Converter={StaticResource BoolToVisibilityConverter}}"/>
              <StackPanel Visibility="{Binding IsStringListType, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Margin="0,8,0,4"/>
                <ItemsControl ItemsSource="{Binding ListItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <CheckBox Content="{Binding Label}"
                                IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,4"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
      <Button Content="Отмена" Width="80" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
